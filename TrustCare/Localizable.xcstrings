    "tos_user_1": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Souhlasíte s tím, že budete poskytovat přesné informace a platformu používat zákonně, s respektem a v dobré víře."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du accepterer at give korrekte oplysninger og bruge platformen lovligt, respektfuldt og i god tro."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie stimmen zu, genaue Informationen bereitzustellen und die Plattform rechtmäßig, respektvoll und in gutem Glauben zu nutzen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You agree to provide accurate information and use the platform lawfully, respectfully, and in good faith."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aceptas proporcionar información precisa y usar la plataforma de forma legal, respetuosa y de buena fe."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous acceptez de fournir des informations exactes et d'utiliser la plateforme de manière légale, respectueuse et de bonne foi."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ön beleegyezik, hogy pontos információkat ad meg, és a platformot jogszerűen, tisztelettudóan és jóhiszeműen használja."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accetti di fornire informazioni accurate e di utilizzare la piattaforma in modo legale, rispettoso e in buona fede."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "U stemt ermee in nauwkeurige informatie te verstrekken en het platform rechtmatig, respectvol en in goed vertrouwen te gebruiken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zgadzasz się podawać dokładne informacje i używać platformy zgodnie z prawem, z szacunkiem i w dobrej wierze."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você concorda em fornecer informações precisas e usar a plataforma de forma legal, respeitosa e de boa-fé."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Ești de acord să furnizezi informații precise și să utilizezi platforma în mod legal, respectuos și cu bună-credință."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы обязуетесь предоставлять точную информацию и использовать платформу законно и добросовестно."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du godkänner att tillhandahålla korrekt information och använda plattformen på ett lagligt, respektfullt och uppriktigt sätt."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Doğru bilgi sağlamayı ve platformu yasal, saygılı ve iyi niyetli bir şekilde kullanmayı kabul edersiniz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви погоджуєтеся надавати достовірну інформацію та використовувати платформу законно, шанобливо і добросовісно."
          }
        }
      }
    },
    "tos_user_2": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nesmíte se pokoušet zneužívat platformu, obcházet bezpečnostní kontroly nebo zasahovat do jiných uživatelů."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du må ikke forsøge at misbruge platformen, omgå sikkerhedskontroller eller forstyrre andre brugere."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie dürfen nicht versuchen, die Plattform zu missbrauchen, Sicherheitskontrollen zu umgehen oder andere Nutzer zu stören."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You must not attempt to abuse the platform, bypass security controls, or interfere with other users."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No debes intentar abusar de la plataforma, evadir los controles de seguridad ni interferir con otros usuarios."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous ne devez pas tenter d'abuser de la plateforme, de contourner les contrôles de sécurité ou d'interférer avec d'autres utilisateurs."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nem kísérelheti meg a platform visszaélésszerű használatát, a biztonsági ellenőrzések megkerülését vagy a többi felhasználó zavarását."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non devi tentare di abusare della piattaforma, eludere i controlli di sicurezza o interferire con altri utenti."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "U mag niet proberen het platform te misbruiken, beveiligingscontroles te omzeilen of andere gebruikers te hinderen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie możesz nadużywać platformy, obchodzić zabezpieczeń ani przeszkadzać innym użytkownikom."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você não deve tentar abusar da plataforma, ignorar controles de segurança ou interferir com outros usuários."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Nu trebuie să încerci să abuzezi platforma, să ocolești controalele de securitate sau să interferezi cu alți utilizatori."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы не должны пытаться злоупотреблять платформой, обходить безопасность или мешать другим пользователям."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du får inte försöka missbruka plattformen, kringgå säkerhetskontroller eller störa andra användare."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Platformu kötüye kullanmaya, güvenlik kontrollerini atlamaya veya diğer kullanıcılara müdahale etmeye çalışmamalısınız."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вам заборонено намагатися зловживати платформою, обходити засоби безпеки або заважати іншим користувачам."
          }
        }
      }
    },
    "tos_user_3": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nesete odpovědnost za odeslaný obsah a za dodržování platných místních zákonů a předpisů."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du er ansvarlig for indhold, du indsender, og for at overholde gældende lokale love og regler."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie sind für die von Ihnen übermittelten Inhalte und für die Einhaltung der geltenden lokalen Gesetze und Vorschriften verantwortlich."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are responsible for content you submit and for complying with applicable local laws and regulations."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eres responsable del contenido que envías y de cumplir con las leyes y regulaciones locales aplicables."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous êtes responsable du contenu que vous soumettez et du respect des lois et réglementations locales applicables."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ön felelős az Ön által beküldött tartalomért, valamint a vonatkozó helyi törvények és előírások betartásáért."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei responsabile dei contenuti che invii e del rispetto delle leggi e normative locali applicabili."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "U bent verantwoordelijk voor de content die u indient en voor het naleven van toepasselijke lokale wet- en regelgeving."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jesteś odpowiedzialny za treści, które przesyłasz, i za przestrzeganie obowiązujących przepisów lokalnych."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você é responsável pelo conteúdo que envia e pelo cumprimento das leis e regulamentos locais aplicáveis."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Ești responsabil pentru conținutul pe care îl trimiți și pentru respectarea legilor și reglementărilor locale aplicabile."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы несете ответственность за свой контент и за соблюдение местного законодательства."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du är ansvarig för det innehåll du skickar in och för att följa tillämpliga lokala lagar och förordningar."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gönderdiğiniz içerikten ve yürürlükteki yerel yasalara ve düzenlemelere uymaktan siz sorumlusunuz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви несете відповідальність за розміщений вами контент та за дотримання чинного місцевого законодавства."
          }
        }
      }
    },
