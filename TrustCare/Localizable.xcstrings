    "error_offline_body" : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vypadá to, že není připojení k internetu. Zkontrolujte připojení a zkuste to znovu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Det ser ud til, at der ikke er internetforbindelse. Tjek din forbindelse og prøv igen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es scheint keine Internetverbindung zu geben. Bitte prüfen Sie Ihre Verbindung und versuchen Sie es erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "It looks like you’re offline. Check your connection and try again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parece que no hay conexión a internet. Revisa tu conexión e inténtalo de nuevo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il semble que vous n’ayez pas de connexion internet. Vérifiez votre connexion et réessayez."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Úgy tűnik, nincs internetkapcsolat. Ellenőrizd a kapcsolatot, majd próbáld újra."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sembra che non ci sia connessione internet. Controlla la connessione e riprova."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Het lijkt erop dat er geen internetverbinding is. Controleer je verbinding en probeer opnieuw."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wygląda na to, że nie ma połączenia z internetem. Sprawdź połączenie i spróbuj ponownie."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parece que você está sem internet. Verifique sua conexão e tente novamente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se pare că nu există conexiune la internet. Verifică conexiunea și încearcă din nou."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Похоже, нет подключения к интернету. Проверьте подключение и попробуйте снова."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Det verkar som att du saknar internetanslutning. Kontrollera anslutningen och försök igen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "İnternet bağlantısı yok gibi görünüyor. Bağlantınızı kontrol edip tekrar deneyin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Схоже, немає підключення до інтернету. Перевірте з’єднання та спробуйте ще раз."
          }
        }
      }
    },
