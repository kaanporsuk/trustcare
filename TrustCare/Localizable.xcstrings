    "tos_user_1" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du accepterer at give korrekte oplysninger og bruge platformen lovligt, respektfuldt og i god tro."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie verpflichten sich, korrekte Angaben zu machen und die Plattform rechtmäßig, respektvoll und in gutem Glauben zu nutzen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You agree to provide accurate information and use the platform lawfully, respectfully, and in good faith."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je stemt ermee in correcte informatie te verstrekken en het platform legaal, respectvol en te goeder trouw te gebruiken."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zobowiązujesz się podawać prawdziwe informacje i korzystać z platformy zgodnie z prawem, z szacunkiem i w dobrej wierze."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doğru bilgi sağlamayı ve platformu yasalara uygun, saygılı ve iyi niyetli şekilde kullanmayı kabul edersiniz."
          }
        }
      }
    },
    "tos_user_2" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du må ikke misbruge platformen, omgå sikkerhedskontroller eller forstyrre andre brugere."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie dürfen die Plattform nicht missbrauchen, Sicherheitsmechanismen umgehen oder andere Nutzer beeinträchtigen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You must not attempt to abuse the platform, bypass security controls, or interfere with other users."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je mag het platform niet misbruiken, beveiligingsmaatregelen omzeilen of andere gebruikers hinderen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nie wolno nadużywać platformy, omijać zabezpieczeń ani zakłócać działania usługi dla innych użytkowników."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Platformu kötüye kullanmamalı, güvenlik kontrollerini aşmaya çalışmamalı veya diğer kullanıcıların deneyimini bozmamalısınız."
          }
        }
      }
    },
    "tos_user_3" : {
      "extractionState" : "stale",
