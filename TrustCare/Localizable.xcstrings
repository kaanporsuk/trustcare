        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre connexion est peut-être instable. Réessayez de charger la liste."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A kapcsolata jelenleg instabil lehet. Próbálja meg újra betölteni a listát."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La tua connessione potrebbe essere instabile. Riprova a caricare l'elenco."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uw verbinding is mogelijk instabiel. Probeer opnieuw de lijst te laden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twoje połączenie może być obecnie niestabilne. Spróbuj ponownie, aby załadować listę."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua conexão pode estar instável no momento. Tente novamente para carregar a lista."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Conexiunea ta ar putea fi instabilă chiar acum. Încearcă din nou pentru a încărca lista."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваше соединение может быть нестабильным. Попробуйте еще раз загрузить список."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Din anslutning kan vara instabil just nu. Försök igen för att ladda listan."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bağlantınız şu anda kararsız olabilir. Listeyi yüklemek için tekrar deneyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "З'єднання може бути нестабільним. Спробуйте завантажити список ще раз."
          }
        }
      }
    },
    "error_load_providers_body_generic": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Poskytovatele se nepodařilo načíst. Zkuste to prosím znovu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kunne ikke indlæse udbydere. Prøv venligst igen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Anbieter konnten nicht geladen werden. Bitte versuchen Sie es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t load providers. Please try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudieron cargar los proveedores. Por favor, inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de charger les professionnels. Veuillez réessayer."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nem sikerült betölteni a szolgáltatókat. Kérjük, próbálja újra."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile caricare i professionisti. Riprova."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Konden zorgaanbieders niet laden. Probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie udało się załadować dostawców. Spróbuj ponownie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível carregar os prestadores. Tente novamente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Nu s-au putut încărca furnizorii. Te rugăm să încerci din nou."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось загрузить специалистов. Пожалуйста, попробуйте еще раз."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kunde inte ladda vårdgivare. Vänligen försök igen."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sağlayıcılar yüklenemedi. Lütfen tekrar deneyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не вдалося завантажити спеціалістів. Спробуйте ще раз."
          }
        }
      }
    },
