    "pp_data_usage_1": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Osobní údaje používáme k poskytování základních funkcí aplikace, přizpůsobení obsahu a udržování bezpečnosti účtu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi bruger personoplysninger til at levere kernefunktionalitet i appen, personalisere indhold og opretholde kontosikkerhed."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir verwenden personenbezogene Daten, um Kernfunktionen der App bereitzustellen, Inhalte zu personalisieren und die Kontosicherheit zu gewährleisten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We use personal data to provide core app functionality, personalize content, and maintain account security."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizamos datos personales para proporcionar las funciones principales de la aplicación, personalizar el contenido y mantener la seguridad de la cuenta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous utilisons les données personnelles pour fournir les fonctionnalités principales de l'application, personnaliser le contenu et maintenir la sécurité du compte."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A személyes adatokat az alkalmazás alapvető funkcióinak biztosítására, a tartalom személyre szabására és a fiók biztonságának fenntartására használjuk."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizziamo i dati personali per fornire le funzionalità principali dell'app, personalizzare i contenuti e mantenere la sicurezza dell'account."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "We gebruiken persoonlijke gegevens om kernfunctionaliteit van de app te bieden, content te personaliseren en accountbeveiliging te handhaven."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Używamy danych osobowych do zapewnienia podstawowych funkcji aplikacji, personalizacji treści i utrzymania bezpieczeństwa konta."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Usamos dados pessoais para fornecer as funcionalidades principais do app, personalizar conteúdo e manter a segurança da conta."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Folosim datele personale pentru a oferi funcționalitățile de bază ale aplicației, pentru a personaliza conținutul și pentru a menține securitatea contului."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы используем данные для работы приложения, персонализации и безопасности аккаунта."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi använder personuppgifter för att tillhandahålla appens kärnfunktioner, anpassa innehåll och upprätthålla kontosäkerhet."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kişisel verileri temel uygulama işlevlerini sağlamak, içeriği kişiselleştirmek ve hesap güvenliğini sağlamak için kullanıyoruz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ми використовуємо персональні дані для надання основних функцій додатку, персоналізації контенту та забезпечення безпеки облікового запису."
          }
        }
      }
    },
    "pp_data_usage_2": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Odeslané recenze a metadata používáme k zajištění důvěry, bezpečnosti, moderování, prevenci podvodů a zajištění kvality."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi bruger indsendte anmeldelser og metadata til tillid, sikkerhed, moderation, bedrageribekæmpelse og kvalitetssikring."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir verwenden eingereichte Bewertungen und Metadaten für Vertrauen, Sicherheit, Moderation, Betrugsprävention und Qualitätssicherung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We use submitted reviews and metadata for trust, safety, moderation, fraud prevention, and quality assurance."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizamos las reseñas enviadas y los metadatos para fines de confianza, seguridad, moderación, prevención de fraude y garantía de calidad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous utilisons les avis soumis et les métadonnées pour la confiance, la sécurité, la modération, la prévention de la fraude et l'assurance qualité."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A beküldött értékeléseket és metaadatokat a bizalom, a biztonság, a moderálás, a csalásmegelőzés és a minőségbiztosítás érdekében használjuk fel."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizziamo le recensioni inviate e i metadati per fiducia, sicurezza, moderazione, prevenzione delle frodi e garanzia di qualità."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "We gebruiken ingediende beoordelingen en metadata voor vertrouwen, veiligheid, moderatie, fraudepreventie en kwaliteitsborging."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Używamy przesłanych opinii i metadanych do zapewnienia zaufania, bezpieczeństwa, moderacji, zapobiegania oszustwom i kontroli jakości."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Usamos avaliações enviadas e metadados para confiança, segurança, moderação, prevenção de fraudes e garantia de qualidade."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Folosim recenziile și metadatele trimise pentru încredere, siguranță, moderare, prevenirea fraudelor și asigurarea calității."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отзывы используются для модерации, безопасности и контроля качества."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi använder inskickade recensioner och metadata för tillit, säkerhet, moderering, bedrägeriförebyggande och kvalitetssäkring."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gönderilen değerlendirmeleri ve meta verileri güven, güvenlik, denetim, dolandırıcılığı önleme ve kalite güvencesi için kullanıyoruz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Надані відгуки та метадані використовуються для забезпечення довіри, безпеки, модерації, запобігання шахрайству та контролю якості."
          }
        }
      }
    },
    "pp_data_usage_3": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "K vylepšení prostředí a spolehlivosti produktu můžeme používat agregované a anonymizované analýzy."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi kan bruge aggregerede og afidentificerede analyser til at forbedre produktoplevelsen og pålideligheden."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir können aggregierte und anonymisierte Analysedaten verwenden, um das Produkterlebnis und die Zuverlässigkeit zu verbessern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We may use aggregated and de-identified analytics to improve product experience and reliability."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Podemos utilizar análisis agregados y anónimos para mejorar la experiencia y fiabilidad del producto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous pouvons utiliser des analyses agrégées et anonymisées pour améliorer l'expérience produit et la fiabilité."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Összesített és anonimizált analitikát használhatunk a termékélmény és a megbízhatóság javítására."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Possiamo utilizzare analisi aggregate e rese anonime per migliorare l'esperienza e l'affidabilità del prodotto."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "We kunnen geaggregeerde en gede-identificeerde analyses gebruiken om de productervaring en betrouwbaarheid te verbeteren."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Możemy wykorzystywać zagregowane i zanonimizowane dane analityczne, aby ulepszać produkt i jego niezawodność."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Podemos usar análises agregadas e desidentificadas para melhorar a experiência e confiabilidade do produto."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Putem folosi analize agregate și de-identificate pentru a îmbunătăți experiența și fiabilitatea produsului."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы можем использовать анонимную аналитику для улучшения продукта."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi kan använda aggregerad och avidentifierad analys för att förbättra produktupplevelsen och tillförlitligheten."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ürün deneyimini ve güvenilirliğini artırmak için toplu ve kimliği gizlenmiş analitiği kullanabiliriz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ми можемо використовувати агреговану та знеособлену аналітику для покращення якості та надійності продукту."
          }
        }
      }
    },
