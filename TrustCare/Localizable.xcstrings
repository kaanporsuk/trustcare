    "tos_contact_2" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ved fortsat brug af tjenesten bekræfter du, at du har læst og accepteret disse vilkår."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durch die weitere Nutzung des Dienstes bestätigen Sie, dass Sie diese Bedingungen gelesen und akzeptiert haben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "By continuing to use the service, you acknowledge that you have read and agreed to these Terms."
