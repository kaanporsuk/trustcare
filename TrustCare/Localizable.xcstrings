    "tos_ip_1": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Veškerý obsah platformy, značky a software jsou majetkem společnosti TrustCare nebo jsou nám licencovány, není-li uvedeno jinak."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Alt platformindhold, branding og software ejes af TrustCare eller er licenseret til os, medmindre andet er angivet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Plattforminhalte, Marken und Software sind Eigentum von TrustCare oder an uns lizenziert, sofern nicht anders angegeben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All platform content, branding, and software are owned by TrustCare or licensed to us, unless otherwise stated."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todo el contenido, las marcas y el software de la plataforma son propiedad de TrustCare o se nos ha otorgado licencia para su uso, salvo que se indique lo contrario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout le contenu, la marque et le logiciel de la plateforme appartiennent à TrustCare ou nous sont concédés sous licence, sauf indication contraire."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Minden platformtartalom, márkaépítés és szoftver a TrustCare tulajdonát képezi, vagy ránk van licencelve, hacsak nincs másképp feltüntetve."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutti i contenuti, il marchio e il software della piattaforma sono di proprietà di TrustCare o concessi in licenza a noi, se non diversamente specificato."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle platformcontent, branding en software zijn eigendom van TrustCare of aan ons gelicentieerd, tenzij anders aangegeven."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wszelkie treści, marka i oprogramowanie platformy są własnością TrustCare lub są nam licencjonowane, o ile nie określono inaczej."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Todo o conteúdo da plataforma, a marca e o software são de propriedade da TrustCare ou licenciados para nós, salvo indicação em contrário."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Tot conținutul platformei, brandingul și software-ul sunt deținute de TrustCare sau ne sunt licențiate, cu excepția cazului în care se specifică altfel."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Весь контент, бренд и ПО платформы принадлежат TrustCare или лицензированы нами."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Allt plattformsinnehåll, varumärke och programvara ägs av TrustCare eller licensieras till oss, om inget annat anges."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aksi belirtilmedikçe, tüm platform içeriği, markalaşma ve yazılım TrustCare'e aittir veya tarafımıza lisanslanmıştır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Увесь контент платформи, бренд та програмне забезпечення належать TrustCare або ліцензовані нами, якщо не вказано інше."
          }
        }
      }
    },
    "tos_ip_2": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nesmíte kopírovat, získávat (scraping), zpětně analyzovat ani dále šířit obsah platformy nad rámec povoleného legálního použití."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du må ikke kopiere, indsamle (scrape), reverse engineere eller videredistribuere platformindhold ud over tilladt lovlig brug."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie dürfen Plattforminhalte nicht über die gesetzlich zulässige Nutzung hinaus kopieren, auslesen (scrapen), zurückentwickeln (Reverse Engineering) oder weiterverbreiten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You may not copy, scrape, reverse engineer, or redistribute platform content beyond permitted legal use."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No puedes copiar, extraer datos (scrape), aplicar ingeniería inversa ni redistribuir contenido de la plataforma más allá del uso legal permitido."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous ne pouvez pas copier, extraire, procéder à une ingénierie inverse ou redistribuer le contenu de la plateforme au-delà de l'utilisation légale autorisée."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nem másolhatja, nem gyűjtheti le, nem fejtheti vissza és nem terjesztheti tovább a platform tartalmát az engedélyezett jogszerű használaton túl."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non puoi copiare, estrarre (scrape), decodificare o ridistribuire i contenuti della piattaforma oltre l'uso legale consentito."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "U mag platformcontent niet kopiëren, scrapen, reverse-engineeren of herdistribueren buiten het toegestane wettelijke gebruik."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie wolno kopiować, pobierać danych (scrape), poddawać inżynierii wstecznej ani rozpowszechniać treści z platformy poza dozwolony użytek."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você não pode copiar, extrair dados, fazer engenharia reversa ou redistribuir o conteúdo da plataforma além do uso legal permitido."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Nu ai voie să copiezi, să extragi, să decodifici (reverse engineer) sau să redistribui conținutul platformei dincolo de utilizarea legală permisă."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вам запрещено копировать, парсить, декомпилировать или распространять контент вне разрешенного использования."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du får inte kopiera, skrapa, bakåtkompilera eller vidaredistribuera plattformsinnehåll utöver tillåten laglig användning."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İzin verilen yasal kullanımın ötesinde platform içeriğini kopyalayamaz, kazıyamaz, tersine mühendislik yapamaz veya yeniden dağıtamazsınız."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви не маєте права копіювати, збирати (скрапінг), здійснювати зворотну розробку або розповсюджувати контент платформи за межами дозволеного законного використання."
          }
        }
      }
    },
    "tos_ip_title": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Duševní vlastnictví"
          }
        },
        "da": {
          "stringUnit": {
