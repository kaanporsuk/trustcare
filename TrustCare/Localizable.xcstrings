    "help_faq_a1" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gå til fanen Anmeldelse, søg efter den sundhedsudbyder du har besøgt, og følg den guidede formular. Anmeldelser publiceres efter behandling og kan kræve verifikation."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gehen Sie zum Reiter Bewertung, suchen Sie den besuchten Anbieter und folgen Sie dem geführten Formular. Bewertungen werden nach Verarbeitung veröffentlicht und können eine Verifizierung erfordern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Go to the Review tab, search for the healthcare provider you visited, and follow the guided form. Reviews are published after processing and may require verification."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ga naar het tabblad Beoordelen, zoek de zorgverlener die je bezocht hebt en volg het begeleide formulier. Beoordelingen worden na verwerking gepubliceerd en kunnen verificatie vereisen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przejdź do zakładki Opinie, wyszukaj odwiedzonego świadczeniodawcę i wypełnij formularz krok po kroku. Opinie są publikowane po przetworzeniu i mogą wymagać weryfikacji."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Değerlendirme sekmesine gidin, ziyaret ettiğiniz sağlayıcıyı arayın ve yönlendirmeli formu tamamlayın. Değerlendirmeler işlendikten sonra yayınlanır ve doğrulama gerekebilir."
          }
        }
      }
    },
    "help_faq_a2" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ja. Åbn Mine anmeldelser, stryg en anmeldelse til venstre, og tryk på Rediger. Af hensyn til integritet kan redigering være begrænset efter publicering."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ja. Öffnen Sie Meine Bewertungen, wischen Sie bei einem Eintrag nach links und tippen Sie auf Bearbeiten. Aus Integritätsgründen können Änderungen nach Veröffentlichung eingeschränkt sein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yes. Open My Reviews, swipe left on a review, and tap Edit. For integrity reasons, edits may be limited after publication and moderation events."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ja. Open Mijn beoordelingen, veeg een item naar links en tik op Bewerken. Om integriteit te waarborgen kunnen bewerkingen na publicatie beperkt zijn."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tak. Otwórz Moje opinie, przesuń wpis w lewo i wybierz Edytuj. Ze względów integralności część zmian po publikacji może być ograniczona."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evet. Değerlendirmelerim ekranında ilgili kaydı sola kaydırıp Düzenle seçeneğine dokunun. Güvenilirlik nedeniyle bazı düzenlemeler yayın sonrası sınırlandırılabilir."
          }
        }
      }
    },
    "help_faq_a3" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verificeret-badget betyder, at anmeldelsen indeholder dokumentation eller har bestået verificeringskontroller. Det garanterer ikke et medicinsk resultat."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Verifiziert-Abzeichen zeigt an, dass die Bewertung Nachweise enthält oder Prüfungen bestanden hat. Es ist keine Garantie für ein medizinisches Ergebnis."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The Verified badge indicates that the review includes supporting evidence or passed verification checks. It does not guarantee any medical outcome."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De Geverifieerd-badge betekent dat de beoordeling ondersteunend bewijs bevat of verificatiecontroles heeft doorstaan. Dit garandeert geen medisch resultaat."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odznaka Zweryfikowano oznacza, że opinia zawiera materiał potwierdzający lub przeszła kontrole weryfikacyjne. Nie stanowi gwarancji efektu medycznego."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doğrulandı rozeti, değerlendirmenin destekleyici kanıt içerdiğini veya doğrulama kontrollerini geçtiğini gösterir. Tıbbi sonuç garantisi vermez."
          }
        }
      }
    },
    "help_faq_a4" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Åbn anmeldelsesdetaljen og brug Rapporter-funktionen. Vores moderationsteam gennemgår rapporter og kan fjerne indhold, der bryder reglerne."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öffnen Sie die Bewertungsdetails und nutzen Sie die Melden-Funktion. Unser Moderationsteam prüft Meldungen und kann regelwidrige Inhalte entfernen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open the review detail and use the Report option. Our moderation team reviews reported content and may remove material that violates platform rules."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open de beoordelingsdetails en gebruik de optie Melden. Ons moderatieteam beoordeelt meldingen en kan inhoud verwijderen die regels schendt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Otwórz szczegóły opinii i użyj opcji Zgłoś. Zespół moderacji analizuje zgłoszenia i może usuwać treści naruszające zasady."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Değerlendirme detay ekranındaki Bildir seçeneğini kullanın. Moderasyon ekibimiz bildirilen içerikleri inceler ve kuralları ihlal eden içerikleri kaldırabilir."
          }
        }
      }
    },
    "help_faq_a5" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kan anmode om sletning i Indstillinger. Vi behandler anmodningen i henhold til lovkrav om opbevaring og bekræfter, når den er fuldført."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie können die Löschung in den Einstellungen anfordern. Wir bearbeiten die Anfrage gemäß gesetzlichen Aufbewahrungspflichten und bestätigen den Abschluss."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can request deletion from Settings. We will process deletion according to legal retention requirements and confirm when the request is complete."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je kunt verwijdering aanvragen via Instellingen. We verwerken dit volgens wettelijke bewaarplichten en bevestigen wanneer het is afgerond."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wniosek o usunięcie możesz złożyć w Ustawieniach. Zrealizujemy go zgodnie z wymogami retencji prawnej i potwierdzimy zakończenie."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ayarlar bölümünden silme talebi oluşturabilirsiniz. Talebinizi yasal saklama yükümlülüklerine göre işler ve tamamlandığında size bildiririz."
          }
        }
      }
    },
    "help_faq_a6" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For konto-, privatlivs- eller teknisk support kan du kontakte support@trustcare.app. Angiv appversion og en kort problem-beskrivelse."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Für Konto-, Datenschutz- oder technische Fragen kontaktieren Sie support@trustcare.app und teilen Sie App-Version sowie eine kurze Problembeschreibung mit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For account, privacy, or technical support, contact support@trustcare.app. Please include your app version and a short problem description."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voor account-, privacy- of technische vragen kun je mailen naar support@trustcare.app. Vermeld je appversie en een korte probleemomschrijving."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "W sprawach konta, prywatności lub problemów technicznych napisz na support@trustcare.app i podaj wersję aplikacji oraz krótki opis problemu."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hesap, gizlilik veya teknik destek için support@trustcare.app adresine yazın. Lütfen uygulama sürümünüzü ve sorunun kısa açıklamasını ekleyin."
          }
        }
      }
    },
