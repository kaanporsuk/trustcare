    "pp_rights_1" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Afhængigt af din region kan du have ret til indsigt, rettelse, eksport, begrænsning eller sletning af personoplysninger."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je nach Region haben Sie Rechte auf Auskunft, Berichtigung, Export, Einschränkung oder Löschung Ihrer personenbezogenen Daten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Depending on your region, you may have rights to access, correct, export, restrict, or delete your personal data."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Afhankelijk van je regio heb je mogelijk rechten op inzage, correctie, export, beperking of verwijdering van persoonsgegevens."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "W zależności od regionu możesz mieć prawo do dostępu, sprostowania, eksportu, ograniczenia lub usunięcia danych osobowych."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bulunduğunuz bölgeye göre kişisel verilerinize erişme, düzeltme, dışa aktarma, kısıtlama veya silme hakkınız olabilir."
          }
        }
      }
    },
    "pp_rights_2" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kan opdatere profiloplysninger i appen eller anmode support om kontorelaterede handlinger."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profilinformationen können Sie in der App aktualisieren oder Unterstützung für kontobezogene Maßnahmen anfordern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can update profile information directly in the app or request support for account-level actions."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je kunt profielinformatie in de app bijwerken of ondersteuning vragen voor accountacties."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dane profilu możesz aktualizować w aplikacji lub poprosić wsparcie o działania na poziomie konta."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profil bilgilerinizi uygulama içinden güncelleyebilir veya hesap işlemleri için destek talep edebilirsiniz."
          }
        }
      }
    },
    "pp_rights_3" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kan gøre indsigelse mod visse behandlinger, hvor det er relevant efter lokal lovgivning."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie können bestimmten Verarbeitungen widersprechen, sofern dies nach lokalem Recht gilt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You may object to certain processing where applicable under local law."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je kunt bezwaar maken tegen bepaalde verwerkingen waar dat onder lokaal recht van toepassing is."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Możesz sprzeciwić się określonemu przetwarzaniu, jeśli wynika to z lokalnych przepisów."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yerel hukuk kapsamında uygun olduğunda belirli işleme faaliyetlerine itiraz edebilirsiniz."
          }
        }
      }
    },
    "pp_rights_4" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For at udøve dine rettigheder, kontakt support@trustcare.app; vi svarer inden for lovpligtige frister."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zur Ausübung Ihrer Rechte kontaktieren Sie support@trustcare.app; wir antworten innerhalb der gesetzlich vorgeschriebenen Fristen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To exercise your rights, contact support@trustcare.app and we will respond within the legally required timeframe."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Om je rechten uit te oefenen, neem contact op via support@trustcare.app; we reageren binnen de wettelijke termijn."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aby skorzystać z praw, napisz na support@trustcare.app; odpowiemy w ustawowych terminach."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haklarınızı kullanmak için support@trustcare.app adresine yazın; yasal sürelerde yanıt veririz."
          }
        }
      }
    },
    "pp_rights_title" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
