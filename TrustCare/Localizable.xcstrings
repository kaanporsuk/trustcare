          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TrustCare biedt zorgverlener-ontdekking, beoordelingsfuncties en informatieve begeleidingshulpmiddelen voor algemeen gebruik."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
