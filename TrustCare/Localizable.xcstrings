    "pp_data_sharing_1": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Údaje sdílíme s poskytovateli služeb, kteří provozují hostingové, analytické, moderační a komunikační systémy."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi deler data med tjenesteudbydere, der driver hosting-, analyse-, moderations- og kommunikationssystemer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir teilen Daten mit Dienstleistern, die Hosting-, Analyse-, Moderations- und Kommunikationssysteme betreiben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We share data with service providers that operate hosting, analytics, moderation, and communication systems."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Compartimos datos con proveedores de servicios que operan sistemas de alojamiento, análisis, moderación y comunicación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous partageons des données avec des prestataires de services qui exploitent les systèmes d'hébergement, d'analyse, de modération et de communication."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Megosztunk adatokat olyan szolgáltatókkal, akik tárhelyet, elemzést, moderálást és kommunikációs rendszereket üzemeltetnek."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Condividiamo i dati con fornitori di servizi che gestiscono sistemi di hosting, analisi, moderazione e comunicazione."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "We delen gegevens met serviceproviders die hosting, analyses, moderatie en communicatiesystemen beheren."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Udostępniamy dane usługodawcom, którzy obsługują systemy hostingu, analityki, moderacji i komunikacji."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Compartilhamos dados com prestadores de serviços que operam sistemas de hospedagem, análise, moderação e comunicação."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Împărtășim date cu furnizorii de servicii care operează sisteme de găzduire, analiză, moderare și comunicare."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы делимся данными с поставщиками услуг: хостинг, аналитика, модерация."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi delar data med tjänsteleverantörer som hanterar hosting, analys, moderering och kommunikationssystem."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Verileri, barındırma, analitik, denetim ve iletişim sistemlerini işleten hizmet sağlayıcılarla paylaşıyoruz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ми ділимося даними з постачальниками послуг, які забезпечують хостинг, аналітику, модерацію та комунікацію."
          }
        }
      }
    },
    "pp_data_sharing_2": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Informace můžeme zveřejnit, pokud to vyžaduje zákon, předpis, právní proces nebo za účelem ochrany uživatelů a integrity platformy."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi kan videregive oplysninger, når det kræves af lov, regulering, juridisk proces, eller for at beskytte brugere og platformens integritet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir können Informationen offenlegen, wenn dies durch Gesetz, Vorschrift oder rechtliche Verfahren vorgeschrieben ist oder um Nutzer und die Integrität der Plattform zu schützen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We may disclose information when required by law, regulation, legal process, or to protect users and platform integrity."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Podemos divulgar información cuando lo requiera la ley, regulaciones, procesos legales o para proteger a los usuarios y la integridad de la plataforma."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous pouvons divulguer des informations lorsque la loi, la réglementation, une procédure judiciaire l'exige, ou pour protéger les utilisateurs et l'intégrité de la plateforme."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Felfedhetünk információkat, ha azt törvény, rendelet, jogi eljárás követeli meg, vagy a felhasználók és a platform integritásának védelme érdekében."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Potremmo divulgare informazioni quando richiesto dalla legge, dai regolamenti, dai procedimenti legali o per proteggere gli utenti e l'integrità della piattaforma."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "We kunnen informatie openbaar maken indien dit vereist is door wet, regelgeving, juridische processen, of ter bescherming van gebruikers en platformintegriteit."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Możemy ujawnić informacje, gdy jest to wymagane przez prawo, przepisy, proces prawny lub w celu ochrony użytkowników i integralności platformy."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Podemos divulgar informações quando exigido por lei, regulamento, processo legal ou para proteger os usuários e a integridade da plataforma."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Putem dezvălui informații atunci când acest lucru este cerut de lege, reglementări, procese legale sau pentru a proteja utilizatorii și integritatea platformei."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы можем раскрыть информацию по требованию закона для защиты пользователей и платформы."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi kan lämna ut information när det krävs enligt lag, förordning, rättslig process eller för att skydda användare och plattformens integritet."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yasalar, yönetmelikler, hukuki süreçler gerektirdiğinde veya kullanıcıları ve platform bütünlüğünü korumak için bilgileri ifşa edebiliriz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ми можемо розкривати інформацію, якщо це вимагається законом, регуляторними органами, для захисту користувачів і цілісності платформи."
          }
        }
      }
    },
    "pp_data_sharing_3": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Osobní údaje třetím stranám neprodáváme."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi sælger ikke personoplysninger til tredjeparter."
          }
        },
        "de": {
