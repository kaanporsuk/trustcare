    "tos_rehber_1": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Služba Rehber poskytuje pouze informační pokyny a nenabízí lékařskou diagnózu, léčbu ani reakci na mimořádné události."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Rehber giver kun informativ vejledning og leverer ikke medicinsk diagnose, behandling eller nødrespons."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Rehber bietet nur informative Orientierung und stellt keine medizinische Diagnose, Behandlung oder Notfallhilfe bereit."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rehber provides informational guidance only and does not provide medical diagnosis, treatment, or emergency response."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Rehber solo proporciona orientación informativa y no provee diagnósticos médicos, tratamientos ni respuesta a emergencias."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rehber fournit uniquement des conseils informatifs et ne fournit pas de diagnostic médical, de traitement ou d'intervention d'urgence."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A Rehber csak információs útmutatást nyújt, és nem biztosít orvosi diagnózist, kezelést vagy vészhelyzeti reagálást."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rehber fornisce solo indicazioni informative e non fornisce diagnosi, trattamenti medici o risposte alle emergenze."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Rehber biedt alleen informatieve begeleiding en levert geen medische diagnose, behandeling of hulp bij noodgevallen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Rehber dostarcza jedynie wskazówek informacyjnych i nie stawia diagnoz, nie zleca leczenia ani nie działa jako pogotowie ratunkowe."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Rehber fornece apenas orientação informativa e não fornece diagnóstico médico, tratamento ou resposta a emergências."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Rehber oferă doar îndrumări informative și nu oferă diagnostic medical, tratament sau intervenție de urgență."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Rehber предоставляет только информационные рекомендации, а не медицинские диагнозы или экстренную помощь."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Rehber ger endast informativ vägledning och tillhandahåller ingen medicinsk diagnos, behandling eller insats i nödsituationer."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rehber yalnızca bilgilendirme amaçlı rehberlik sağlar ve tıbbi teşhis, tedavi veya acil durum müdahalesi sunmaz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Rehber надає лише інформаційні рекомендації і не ставить медичних діагнозів, не призначає лікування та не надає екстреної медичної допомоги."
          }
        }
      }
    },
    "tos_rehber_2": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "V naléhavých nebo život ohrožujících situacích okamžitě kontaktujte místní záchranné služby."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "I akutte eller livstruende situationer skal du straks kontakte den lokale alarmcentral."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenden Sie sich in dringenden oder lebensbedrohlichen Situationen sofort an den örtlichen Rettungsdienst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "In urgent or life-threatening situations, contact local emergency services immediately."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En situaciones urgentes o que amenacen la vida, comunícate inmediatamente con los servicios de emergencia locales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "En cas d'urgence ou de danger de mort, contactez immédiatement les services d'urgence locaux."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Sürgős vagy életveszélyes helyzetekben azonnal lépjen kapcsolatba a helyi segélyhívó szolgálatokkal."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "In situazioni urgenti o pericolose per la vita, contatta immediatamente i servizi di emergenza locali."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Neem in urgente of levensbedreigende situaties onmiddellijk contact op met lokale hulpdiensten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "W sytuacjach nagłych lub zagrażających życiu natychmiast skontaktuj się z lokalnymi służbami ratunkowymi."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Em situações urgentes ou com risco de vida, contate imediatamente os serviços de emergência locais."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "În situații urgente sau care pun viața în pericol, contactează imediat serviciile locale de urgență."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В экстренных случаях немедленно обращайтесь в местные службы спасения."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontakta omedelbart lokala larmtjänster i brådskande eller livshotande situationer."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Acil veya hayati tehlike arz eden durumlarda derhal yerel acil servislerle iletişime geçin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "У невідкладних або небезпечних для життя ситуаціях негайно звертайтеся до місцевих служб екстреної допомоги."
          }
        }
      }
    },
    "tos_rehber_3": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nadále nesete odpovědnost za svá zdravotní rozhodnutí a měli byste se poradit s kvalifikovanými lékaři."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du er fortsat ansvarlig for sundhedsbeslutninger og bør konsultere kvalificerede læger."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie bleiben für gesundheitliche Entscheidungen verantwortlich und sollten qualifiziertes medizinisches Fachpersonal konsultieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You remain responsible for healthcare decisions and should consult qualified medical professionals."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tú sigues siendo responsable de las decisiones sobre el cuidado de tu salud y debes consultar a profesionales médicos calificados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous restez responsable des décisions liées à votre santé et devez consulter des professionnels de santé qualifiés."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ön továbbra is felelős az egészségügyi döntésekért, és szakképzett orvoshoz kell fordulnia."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimani responsabile per le decisioni sanitarie e dovresti consultare professionisti medici qualificati."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "U blijft verantwoordelijk voor medische beslissingen en dient een gekwalificeerde arts te raadplegen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pozostajesz odpowiedzialny za decyzje dotyczące swojego zdrowia i powinieneś skonsultować się z wykwalifikowanym lekarzem."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você continua sendo responsável pelas decisões de saúde e deve consultar profissionais médicos qualificados."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Rămâi responsabil pentru deciziile referitoare la asistența medicală și ar trebui să consulți profesioniști medicali calificați."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы несете ответственность за решения, касающиеся вашего здоровья, и должны консультироваться с врачами."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du bär fortfarande ansvaret för beslut rörande din hälsa och bör rådfråga kvalificerad sjukvårdspersonal."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sağlık hizmeti kararlarından siz sorumlusunuz ve nitelikli tıbbi uzmanlara danışmalısınız."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви несете повну відповідальність за рішення щодо вашого здоров'я і повинні консультуватися з кваліфікованими лікарями."
          }
        }
      }
    },
