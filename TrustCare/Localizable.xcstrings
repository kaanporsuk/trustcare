    "find_state_try_another_area": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Chcete-li pokračovat, zkuste jinou oblast nebo vyberte jiné město."
          }
        },
