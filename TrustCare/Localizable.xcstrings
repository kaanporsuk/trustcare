    "language_changed_message": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro použití nového jazyka je nutné restartovat aplikaci."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Appen skal genstarte for at anvende det nye sprog."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die App muss neu gestartet werden, um die neue Sprache anzuwenden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The app needs to restart to apply the new language."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La aplicación debe reiniciarse para aplicar el nuevo idioma."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'application doit redémarrer pour appliquer la nouvelle langue."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az alkalmazásnak újra kell indulnia az új nyelv alkalmazásához."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'app deve essere riavviata per applicare la nuova lingua."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De app moet opnieuw worden opgestart om de nieuwe taal toe te passen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikacja musi zostać uruchomiona ponownie, aby zastosować nowy język."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O app precisa ser reiniciado para aplicar o novo idioma."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplicația trebuie să repornească pentru a aplica noua limbă."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для применения нового языка необходимо перезапустить приложение."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Appen måste startas om för att tillämpa det nya språket."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yeni dilin uygulanması için uygulamanın yeniden başlatılması gerekiyor."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Додаток потрібно перезапустити, щоб застосувати нову мову."
          }
        }
      }
    },
