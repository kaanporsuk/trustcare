    "help_faq_a5": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přejděte do Nastavení a požádejte o smazání. Po dokončení vám to potvrdíme."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Gå til Indstillinger og anmod om sletning. Vi bekræfter, når det er gennemført."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gehen Sie zu Einstellungen und fordern Sie die Löschung an. Wir bestätigen, wenn der Vorgang abgeschlossen ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Go to Settings and request deletion. We will confirm when completed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ve a Configuración y solicita la eliminación. Te confirmaremos cuando se complete."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Allez dans Paramètres et demandez la suppression. Nous confirmerons une fois terminé."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Lépjen a Beállításokba, és kérje a törlést. Megerősítjük, amint elkészült."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vai su Impostazioni e richiedi l'eliminazione. Confermeremo una volta completata."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ga naar Instellingen en vraag verwijdering aan. We bevestigen wanneer dit is voltooid."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przejdź do Ustawień i poproś o usunięcie. Potwierdzimy po zakończeniu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Vá para Configurações e solicite a exclusão. Confirmaremos quando concluído."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Mergi la Setări și solicită ștergerea. Vom confirma când se va finaliza."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перейдите в 'Настройки' и запросите удаление. Мы подтвердим, когда все будет готово."
          }
        },
        "sv": {
