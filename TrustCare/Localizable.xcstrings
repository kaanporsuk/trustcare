    "rehber_onboarding_warning": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Tato služba není lékařskou diagnózou ani doporučením léčby. Vždy se poraďte se zdravotnickým pracovníkem."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Denne tjeneste er ikke en medicinsk diagnose eller behandlingsanbefaling. Konsulter altid en sundhedsprofessionel."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Dieser Dienst stellt keine medizinische Diagnose oder Behandlungsempfehlung dar. Konsultieren Sie immer medizinisches Fachpersonal."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ This service is not a medical diagnosis or treatment recommendation. Always consult a healthcare professional."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Este servicio no es un diagnóstico médico ni una recomendación de tratamiento. Consulta siempre a un profesional de la salud."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Ce service n'est pas un diagnostic médical ou une recommandation de traitement. Consultez toujours un professionnel de santé."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Ez a szolgáltatás nem nyújt orvosi diagnózist vagy kezelési javaslatot. Mindig konzultáljon egészségügyi szakemberrel."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Questo servizio non è una diagnosi medica o una raccomandazione di trattamento. Consulta sempre un professionista sanitario."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Deze service is geen medische diagnose of behandelingsadvies. Raadpleeg altijd een medische professional."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Ten serwis nie służy do diagnozowania ani zlecania leczenia. Zawsze konsultuj się z lekarzem."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Este serviço não é um diagnóstico médico ou recomendação de tratamento. Consulte sempre um profissional de saúde."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Acest serviciu nu este un diagnostic medical sau o recomandare de tratament. Consultă întotdeauna un medic."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Эта служба не предоставляет медицинские диагнозы или рекомендации по лечению. Всегда консультируйтесь с врачом."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Denna tjänst är inte en medicinsk diagnos eller behandlingsrekommendation. Rådfråga alltid sjukvårdspersonal."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Bu hizmet bir tıbbi teşhis veya tedavi önerisi değildir. Her zaman bir sağlık uzmanına danışın."
