    "rehber_delete_conversation_message": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tímto trvale smažete tuto konverzaci a všechny její zprávy."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette vil permanent slette denne samtale og alle dens beskeder."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch wird diese Unterhaltung mit allen Nachrichten dauerhaft gelöscht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will permanently delete this conversation and all its messages."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto eliminará permanentemente esta conversación y todos sus mensajes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprimera définitivement cette conversation et tous ses messages."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ezzel véglegesen törli ezt a beszélgetést és az összes üzenetét."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo eliminerà permanentemente questa conversazione e tutti i suoi messaggi."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit zal dit gesprek en alle berichten permanent verwijderen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To trwale usunie tę konwersację i wszystkie jej wiadomości."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso excluirá permanentemente esta conversa e todas as suas mensagens."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Aceasta va șterge permanent această conversație și toate mesajele sale."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это действие навсегда удалит эту беседу и все сообщения."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Detta kommer att permanent radera denna konversation och alla dess meddelanden."
