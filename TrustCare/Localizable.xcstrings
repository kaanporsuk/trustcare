    "tos_service_1" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TrustCare tilbyder søgning efter sundhedsudbydere, anmeldelsesfunktioner og generelle informationsværktøjer."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TrustCare bietet die Suche nach Gesundheitsanbietern, Bewertungsfunktionen und allgemeine Informationshilfen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
