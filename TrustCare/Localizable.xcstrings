    },
    "tos_ip_2" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du må ikke kopiere, scrape, reverse-engineere eller videredistribuere platformindhold ud over lovligt tilladt brug."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie dürfen Inhalte nicht kopieren, scrapen, rückentwickeln oder außerhalb zulässiger gesetzlicher Nutzung weiterverbreiten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You may not copy, scrape, reverse engineer, or redistribute platform content beyond permitted legal use."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je mag platforminhoud niet kopiëren, scrapen, reverse-engineeren of herdistribueren buiten wettelijk toegestane gebruiksvormen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nie wolno kopiować, scrapować, odtwarzać ani redystrybuować treści poza dozwolonym zakresem prawa."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "İzin verilen yasal kullanım dışında platform içeriğini kopyalayamaz, kazıyamaz, tersine mühendislik yapamaz veya yeniden dağıtamazsınız."
          }
        }
