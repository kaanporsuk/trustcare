    "tos_dispute_1" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disse vilkår er underlagt lovgivningen i tjenesteudbyderens jurisdiktion, medmindre ufravigelig lokal lov bestemmer andet."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Bedingungen unterliegen den Gesetzen der zuständigen Gerichtsbarkeit des Diensteanbieters, sofern zwingendes lokales Recht nichts anderes bestimmt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "These Terms are governed by applicable laws of the jurisdiction where the service operator is established, unless local mandatory law provides otherwise."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deze voorwaarden vallen onder het recht van de jurisdictie van de dienstverlener, tenzij dwingend lokaal recht anders bepaalt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niniejsze Warunki podlegają prawu jurysdykcji operatora usługi, chyba że bezwzględnie obowiązujące prawo lokalne stanowi inaczej."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu Koşullar, aksi zorunlu yerel hukuk hükümleri saklı kalmak üzere hizmet sağlayıcının bulunduğu yargı alanı hukukuna tabidir."
          }
        }
      }
    },
    "tos_dispute_2" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Før formelle skridt tages, accepterer du at kontakte os i god tro for at søge en uformel løsning."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vor formalen Verfahren verpflichten Sie sich, uns in gutem Glauben zu kontaktieren, um eine informelle Lösung zu suchen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Before initiating formal proceedings, you agree to contact us in good faith to seek an informal resolution."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voordat je formele procedures start, ga je ermee akkoord eerst in goed vertrouwen contact met ons op te nemen voor een informele oplossing."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przed wszczęciem formalnego postępowania zobowiązujesz się skontaktować z nami w dobrej wierze w celu polubownego rozwiązania."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resmi yollara başvurmadan önce, iyi niyetli bir şekilde bizimle iletişime geçerek dostane çözüm aramayı kabul edersiniz."
          }
        }
      }
    },
