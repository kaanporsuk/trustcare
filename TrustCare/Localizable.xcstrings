    "legal_translation_disclaimer": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Překlad je poskytován pro pohodlí; rozhodující je anglická verze."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Oversættelsen stilles til rådighed for nemheds skyld; den engelske version er gældende."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Übersetzung wird aus Komfortgründen bereitgestellt; die englische Version ist maßgeblich."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Translation is provided for convenience; the English version prevails."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La traducción se proporciona por comodidad; la versión en inglés prevalece."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La traduction est fournie par commodité ; la version anglaise prévaut."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A fordítás a kényelmet szolgálja; az angol verzió az irányadó."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La traduzione è fornita per comodità; prevale la versione inglese."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vertaling wordt aangeboden voor uw gemak; de Engelse versie is leidend."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tłumaczenie ma charakter pomocniczy; rozstrzygająca jest wersja angielska."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A tradução é fornecida por conveniência; a versão em inglês prevalece."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Traducerea este oferită pentru comoditate; versiunea în limba engleză prevalează."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перевод предоставляется для удобства; английская версия имеет преимущественную силу."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Översättningen tillhandahålls för bekvämlighet; den engelska versionen har företräde."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Çeviri kolaylık sağlamak amacıyla sunulmuştur; İngilizce sürüm geçerlidir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Переклад надається для зручності; англійська версія має переважну силу."
          }
        }
      }
    },
