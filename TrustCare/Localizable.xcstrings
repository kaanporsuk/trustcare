    "rehber_disclaimer": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nejedná se o lékařskou radu. Vždy se poraďte se zdravotnickým pracovníkem."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette er ikke medicinsk rådgivning. Konsulter altid en sundhedsprofessionel."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies ist keine medizinische Beratung. Konsultieren Sie immer medizinisches Fachpersonal."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
