    "error_offline_body": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zdá se, že jste offline. Zkontrolujte připojení a zkuste to znovu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Det ser ud til, at du er offline. Tjek din forbindelse og prøv igen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es sieht so aus, als wären Sie offline. Überprüfen Sie Ihre Verbindung und versuchen Sie es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It looks like you’re offline. Check your connection and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Parece que estás sin conexión. Verifica tu conexión y vuelve a intentarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous semblez être hors ligne. Vérifiez votre connexion et réessayez."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Úgy tűnik, offline állapotban van. Ellenőrizze a kapcsolatot, és próbálja újra."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sembra che tu sia offline. Controlla la tua connessione e riprova."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het lijkt erop dat u offline bent. Controleer uw verbinding en probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wygląda na to, że jesteś offline. Sprawdź swoje połączenie i spróbuj ponownie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Parece que você está offline. Verifique sua conexão e tente novamente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Se pare că ești offline. Verifică conexiunea și încearcă din nou."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Похоже, вы оффлайн. Проверьте подключение и попробуйте снова."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det verkar som att du är offline. Kontrollera din anslutning och försök igen."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Çevrimdışı görünüyorsunuz. Bağlantınızı kontrol edip tekrar deneyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Схоже, ви офлайн. Перевірте з'єднання і спробуйте ще раз."
          }
        }
      }
    },
