    },
    "tos_service_2" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tjenestens tilgængelighed og funktioner kan ændre sig over tid; vi kan opdatere eller afvikle dele af tjenesten uden forudgående varsel."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verfügbarkeit und Funktionen können sich ändern; wir können Teile des Dienstes ohne vorherige Ankündigung aktualisieren oder einstellen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Service availability, features, and access may change over time; we may update or discontinue parts of the service without prior notice."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beschikbaarheid en functies van de dienst kunnen wijzigen; onderdelen kunnen zonder voorafgaande kennisgeving worden aangepast of beëindigd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dostępność i funkcje usługi mogą się zmieniać; możemy aktualizować lub wycofywać elementy usługi bez uprzedzenia."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hizmetin kullanılabilirliği ve özellikleri zaman içinde değişebilir; bazı bölümleri önceden bildirim olmadan güncelleyebilir veya sonlandırabiliriz."
          }
        }
      }
    },
