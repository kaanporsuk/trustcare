    "tos_rehber_1" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rehber giver kun informationsbaseret vejledning og tilbyder ikke medicinsk diagnose, behandling eller nødhjælp."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rehber bietet nur allgemeine Gesundheitsinformationen und keine medizinische Diagnose, Behandlung oder Notfallversorgung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rehber provides informational guidance only and does not provide medical diagnosis, treatment, or emergency response."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rehber biedt uitsluitend informatieve begeleiding en geen medische diagnose, behandeling of noodhulp."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rehber dostarcza wyłącznie informacje i wskazówki, nie zapewnia diagnozy medycznej, leczenia ani pomocy ratunkowej."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rehber yalnızca bilgilendirme amaçlı yönlendirme sunar; tıbbi teşhis, tedavi veya acil müdahale hizmeti vermez."
          }
        }
      }
    },
    "tos_rehber_2" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ved akutte eller livstruende situationer skal du straks kontakte lokale alarmtjenester."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bei dringenden oder lebensbedrohlichen Situationen wenden Sie sich sofort an den örtlichen Notdienst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In urgent or life-threatening situations, contact local emergency services immediately."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neem bij urgente of levensbedreigende situaties onmiddellijk contact op met lokale hulpdiensten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "W sytuacjach nagłych lub zagrażających życiu niezwłocznie skontaktuj się z lokalnymi służbami ratunkowymi."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acil veya hayati risk durumlarında derhal yerel acil servislerle iletişime geçin."
          }
        }
      }
    },
    "tos_rehber_3" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du er fortsat ansvarlig for sundhedsbeslutninger og bør rådføre dig med kvalificerede sundhedsprofessionelle."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie tragen die Verantwortung für Gesundheitsentscheidungen und sollten qualifizierte medizinische Fachkräfte konsultieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You remain responsible for healthcare decisions and should consult qualified medical professionals."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je blijft zelf verantwoordelijk voor zorgbeslissingen en dient gekwalificeerde zorgprofessionals te raadplegen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odpowiedzialność za decyzje zdrowotne pozostaje po Twojej stronie; skonsultuj się z wykwalifikowanym specjalistą medycznym."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sağlıkla ilgili kararların sorumluluğu size aittir; yetkin sağlık profesyonellerine danışmanız gerekir."
          }
        }
