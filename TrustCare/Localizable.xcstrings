    "pp_contact_1": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Máte-li dotazy týkající se těchto Zásad ochrany osobních údajů nebo vašich osobních údajů, kontaktujte nás na adrese support@trustcare.app."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvis du har spørgsmål om denne privatlivspolitik eller dine personoplysninger, kan du kontakte os på support@trustcare.app."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Sie Fragen zu dieser Datenschutzerklärung oder Ihren personenbezogenen Daten haben, kontaktieren Sie uns unter support@trustcare.app."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you have questions about this Privacy Policy or your personal data, contact us at support@trustcare.app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si tienes preguntas sobre esta Política de privacidad o tus datos personales, contáctanos en support@trustcare.app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si vous avez des questions concernant cette Politique de confidentialité ou vos données personnelles, contactez-nous à support@trustcare.app."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ha kérdése van az Adatvédelmi Irányelvekkel vagy a személyes adataival kapcsolatban, lépjen kapcsolatba velünk a support@trustcare.app címen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "In caso di domande sulla presente Informativa sulla privacy o sui tuoi dati personali, contattaci a support@trustcare.app."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als u vragen heeft over dit Privacybeleid of uw persoonlijke gegevens, neem dan contact met ons op via support@trustcare.app."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeśli masz pytania dotyczące tej Polityki prywatności lub swoich danych osobowych, skontaktuj się z nami pod adresem support@trustcare.app."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Se você tiver dúvidas sobre esta Política de Privacidade ou sobre seus dados pessoais, contate-nos em support@trustcare.app."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Dacă ai întrebări despre această Politică de confidențialitate sau datele tale personale, contactează-ne la support@trustcare.app."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если у вас есть вопросы о Политике конфиденциальности или ваших данных, свяжитесь с нами: support@trustcare.app."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Om du har frågor om denna integritetspolicy eller dina personuppgifter, kontakta oss på support@trustcare.app."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu Gizlilik Politikası veya kişisel verileriniz hakkında sorularınız varsa support@trustcare.app adresinden bizimle iletişime geçin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Якщо у вас є питання щодо цієї Політики конфіденційності або ваших персональних даних, напишіть нам на support@trustcare.app."
          }
        }
      }
    },
    "pp_contact_2": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pokud se nacházíte v EHP/UK, můžete se také obrátit na místní úřad pro ochranu údajů."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvis du befinder dig i EØS/Storbritannien, kan du også kontakte din lokale databeskyttelsesmyndighed."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Sie sich im EWR/UK befinden, können Sie sich auch an Ihre lokale Datenschutzbehörde wenden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you are in the EEA/UK, you may also contact your local data protection authority."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si te encuentras en el EEE/Reino Unido, también puedes ponerte en contacto con tu autoridad local de protección de datos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si vous êtes dans l'EEE/Royaume-Uni, vous pouvez également contacter votre autorité locale de protection des données."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ha Ön az EGT/Egyesült Királyság területén tartózkodik, kapcsolatba léphet a helyi adatvédelmi hatósággal is."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se ti trovi nel SEE/Regno Unito, puoi anche contattare la tua autorità locale per la protezione dei dati."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als u in de EER/VK bent, kunt u ook contact opnemen met uw lokale gegevensbeschermingsautoriteit."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeśli znajdujesz się w EOG/Wielkiej Brytanii, możesz również skontaktować się z lokalnym organem ochrony danych."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Se você estiver no EEE/Reino Unido, também pode contatar a autoridade local de proteção de dados."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Dacă te afli în SEE/Regatul Unit, poți contacta și autoritatea locală de protecție a datelor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если вы находитесь в ЕЭЗ/Великобритании, вы также можете обратиться в местный орган по защите данных."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Om du befinner dig i EES/Storbritannien kan du även kontakta din lokala dataskyddsmyndighet."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "AEA/Birleşik Krallık'taysanız yerel veri koruma makamınızla da iletişime geçebilirsiniz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Якщо ви перебуваєте в ЄЕЗ/Великобританії, ви також можете звернутися до місцевого органу захисту даних."
          }
        }
      }
    },
