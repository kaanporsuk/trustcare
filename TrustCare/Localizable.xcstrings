    "report_footer": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Uveďte prosím jakékoli další souvislosti, které by nám mohly pomoci tuto zprávu přezkoumat."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Giv venligst enhver yderligere kontekst, der kan hjælpe os med at gennemgå denne anmeldelse."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitte geben Sie alle zusätzlichen Informationen an, die uns bei der Prüfung dieser Meldung helfen könnten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please provide any additional context that might help us review this report."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Por favor, proporciona cualquier contexto adicional que nos ayude a revisar este reporte."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Veuillez fournir tout contexte supplémentaire pouvant nous aider à examiner ce signalement."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Kérjük, adjon meg minden olyan további információt, amely segíthet a jelentés kivizsgálásában."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fornisci qualsiasi contesto aggiuntivo che possa aiutarci a esaminare questa segnalazione."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geef extra context die ons kan helpen deze melding te beoordelen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Proszę podać dodatkowe informacje, które mogą nam pomóc w rozpatrzeniu tego zgłoszenia."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Forneça qualquer contexto adicional que possa nos ajudar a analisar esta denúncia."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Te rugăm să oferi orice context suplimentar care ne-ar putea ajuta să revizuim acest raport."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пожалуйста, предоставьте любую информацию, которая поможет нам рассмотреть эту жалобу."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
