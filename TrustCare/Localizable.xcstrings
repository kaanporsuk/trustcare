    "error_load_providers_body" : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Baglanti simdi stabil olmayabilir. Tekrar denediginizde liste yuklenir."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forbindelsen kan vaere ustabil lige nu. Prov igen for at hente listen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Verbindung ist momentan moglicherweise instabil. Versuchen Sie es erneut, um die Liste zu laden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your connection may be unstable right now. Try again to load the list."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu conexion puede estar inestable en este momento. Vuelve a intentarlo para cargar la lista."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre connexion peut etre instable pour le moment. Reessayez pour charger la liste."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A kapcsolat jelenleg instabil lehet. Probald ujra a lista betoltesehez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La connessione potrebbe essere instabile in questo momento. Riprova per caricare l'elenco."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je verbinding kan nu instabiel zijn. Probeer opnieuw om de lijst te laden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Polaczenie moze byc teraz niestabilne. Sprobuj ponownie, aby zaladowac liste."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sua conexao pode estar instavel agora. Tente novamente para carregar a lista."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conexiunea poate fi instabila acum. Incearca din nou pentru a incarca lista."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seychas soedinenie mozhet byt nestabilnym. Popytaites snova zagruzit spisok."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Din anslutning kan vara instabil just nu. Forsok igen for att ladda listan."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bağlantınız su anda dengesiz olabilir. Listeyi yuklemek icin tekrar deneyin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaraz ziednannia mozhe buty nestabilnym. Sprobuite shche raz, shchob zavantazhyty spysok."
          }
        }
      }
    },
    "error_load_providers_body_generic" : {
