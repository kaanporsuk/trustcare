    "pp_data_collection_1": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Shromažďujeme údaje o účtu, jako je e-mail, jméno, předvolby profilu a ověřovací metadata."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi indsamler kontodata såsom e-mail, navn, profilpræferencer og godkendelsesmetadata."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir erfassen Kontodaten wie E-Mail, Name, Profilpräferenzen und Metadaten zur Authentifizierung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We collect account data such as email, name, profile preferences, and authentication metadata."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recopilamos datos de la cuenta como el correo electrónico, nombre, preferencias de perfil y metadatos de autenticación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous collectons des données de compte telles que l'e-mail, le nom, les préférences de profil et les métadonnées d'authentification."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Olyan fiókadatokat gyűjtünk, mint az e-mail cím, név, profil beállítások és hitelesítési metaadatok."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Raccogliamo i dati dell'account come e-mail, nome, preferenze del profilo e metadati di autenticazione."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "We verzamelen accountgegevens zoals e-mail, naam, profielvoorkeuren en authenticatiemetadata."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zbieramy dane konta, takie jak e-mail, imię, preferencje profilu i metadane uwierzytelniania."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Coletamos dados da conta, como e-mail, nome, preferências de perfil e metadados de autenticação."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Colectăm date despre cont, cum ar fi e-mailul, numele, preferințele profilului și metadatele de autentificare."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы собираем данные аккаунта: e-mail, имя, настройки профиля и метаданные аутентификации."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi samlar in kontouppgifter som e-post, namn, profilinställningar och autentiseringsmetadata."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "E-posta, ad, profil tercihleri ve kimlik doğrulama meta verileri gibi hesap verilerini topluyoruz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ми збираємо дані облікового запису, такі як e-mail, ім'я, налаштування профілю та метадані автентифікації."
          }
        }
      }
    },
    "pp_data_collection_2": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Když odešlete recenze, shromažďujeme hodnocení, komentáře, volitelná média a volitelné ověřovací artefakty."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Når du indsender anmeldelser, indsamler vi bedømmelser, kommentarer, valgfrie medier og valgfrie verifikationsbeviser."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Sie Bewertungen einreichen, erfassen wir Bewertungen, Kommentare, optionale Medien und optionale Nachweise zur Verifizierung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When you submit reviews, we collect ratings, comments, optional media, and optional verification artifacts."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando envías reseñas, recopilamos calificaciones, comentarios, contenido multimedia opcional y documentos de verificación opcionales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque vous soumettez des avis, nous collectons les notes, les commentaires, les médias facultatifs et les preuves de vérification facultatives."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Amikor értékeléseket küld be, összegyűjtjük a minősítéseket, a megjegyzéseket, az opcionális médiát és az opcionális ellenőrzési dokumentumokat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando invii recensioni, raccogliamo valutazioni, commenti, contenuti multimediali opzionali e documenti di verifica opzionali."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wanneer u beoordelingen indient, verzamelen we scores, opmerkingen, optionele media en optionele verificatiedocumenten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gdy przesyłasz opinie, zbieramy oceny, komentarze, opcjonalne multimedia i opcjonalne materiały weryfikacyjne."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando você envia avaliações, coletamos classificações, comentários, mídias opcionais e artefatos de verificação opcionais."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Când trimiți recenzii, colectăm evaluări, comentarii, elemente media opționale și dovezi de verificare opționale."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда вы оставляете отзывы, мы собираем оценки, комментарии, медиа и файлы для проверки."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "När du skickar in recensioner samlar vi in betyg, kommentarer, valfria media och valfria verifikationsdokument."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Değerlendirmeler gönderdiğinizde, puanlamaları, yorumları, isteğe bağlı medyayı ve isteğe bağlı doğrulama eserlerini topluyoruz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Коли ви залишаєте відгуки, ми збираємо оцінки, коментарі, медіа та файли для підтвердження (якщо надано)."
          }
        }
      }
    },
    "pp_data_collection_3": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Můžeme zpracovávat údaje o zařízení a využití, včetně událostí v aplikaci, přibližné polohy a diagnostiky."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi kan behandle enheds- og brugsdata, herunder app-hændelser, omtrentlig lokation og diagnostik."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir können Geräte- und Nutzungsdaten verarbeiten, einschließlich App-Ereignissen, ungefährem Standort und Diagnosen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We may process device and usage data including app events, approximate location, and diagnostics."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Podemos procesar datos de dispositivos y uso, incluyendo eventos de la app, ubicación aproximada y diagnósticos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous pouvons traiter les données de l'appareil et d'utilisation, y compris les événements de l'application, l'emplacement approximatif et les diagnostics."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Feldolgozhatjuk az eszköz- és használati adatokat, beleértve az alkalmazás eseményeit, a hozzávetőleges helyet és a diagnosztikát."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Possiamo elaborare i dati del dispositivo e di utilizzo, inclusi gli eventi dell'app, la posizione approssimativa e la diagnostica."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "We kunnen apparaat- en gebruiksgegevens verwerken, waaronder app-gebeurtenissen, geschatte locatie en diagnostiek."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Możemy przetwarzać dane urządzenia i użytkowania, w tym zdarzenia aplikacji, przybliżoną lokalizację i dane diagnostyczne."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Podemos processar dados do dispositivo e de uso, incluindo eventos do app, localização aproximada e diagnósticos."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Putem procesa datele dispozitivului și de utilizare, inclusiv evenimentele din aplicație, locația aproximativă și diagnosticele."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы можем обрабатывать данные об устройстве, событиях в приложении и примерном местоположении."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi kan behandla enhets- och användningsdata, inklusive app-händelser, ungefärlig plats och diagnostik."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uygulama etkinlikleri, yaklaşık konum ve tanılama dahil olmak üzere cihaz ve kullanım verilerini işleyebiliriz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ми можемо обробляти дані пристрою та використання, зокрема події в додатку, приблизну локацію та діагностичні дані."
          }
        }
      }
    },
    "pp_data_collection_4": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nezáměrně neshromažďujeme citlivé zdravotní záznamy nad rámec informací, které se rozhodnete odeslat."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi indsamler ikke bevidst følsomme sundhedsjournaler ud over de oplysninger, du vælger at indsende."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir erfassen nicht absichtlich sensible Gesundheitsdaten, die über die von Ihnen übermittelten Informationen hinausgehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We do not intentionally collect sensitive health records beyond the information you choose to submit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No recopilamos intencionadamente registros de salud sensibles más allá de la información que eliges enviar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous ne collectons pas intentionnellement de dossiers médicaux sensibles au-delà des informations que vous choisissez de soumettre."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Szándékosan nem gyűjtünk érzékeny egészségügyi nyilvántartásokat azon információkon túl, amelyeket Ön önként megad."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non raccogliamo intenzionalmente cartelle cliniche sensibili oltre alle informazioni che scegli di inviare."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "We verzamelen niet opzettelijk gevoelige medische dossiers buiten de informatie die u ervoor kiest om in te dienen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie zbieramy celowo poufnych dokumentacji medycznej poza informacjami, które zdecydujesz się przesłać."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não coletamos intencionalmente registros de saúde confidenciais além das informações que você escolhe enviar."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Nu colectăm intenționat dosare medicale sensibile dincolo de informațiile pe care alegi să le trimiți."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы не собираем конфиденциальные медицинские данные сверх тех, которые вы сами предоставляете."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi samlar inte avsiktligt in känsliga hälsojournaler utöver den information du väljer att skicka in."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Göndermeyi seçtiğiniz bilgilerin ötesinde, kasıtlı olarak hassas sağlık kayıtları toplamıyoruz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ми не збираємо навмисно конфіденційні медичні записи поза інформацією, яку ви вирішили надати."
          }
        }
      }
    },
