    "claim_submitted_message": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Váš nárok posoudíme do 1-3 pracovních dnů. O schválení vás budeme informovat."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi gennemgår dit krav inden for 1-3 hverdage. Du får besked, når det er godkendt."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir prüfen Ihren Anspruch innerhalb von 1-3 Werktagen. Sie werden benachrichtigt, sobald er genehmigt wurde."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We'll review your claim within 1-3 business days. You'll be notified when it's approved."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revisaremos tu reclamación en 1 a 3 días hábiles. Te notificaremos cuando sea aprobada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous examinerons votre demande sous 1 à 3 jours ouvrés. Vous serez informé de son approbation."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Igénylését 1-3 munkanapon belül elbíráljuk. Értesítjük, amint jóváhagyásra került."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esamineremo la tua richiesta entro 1-3 giorni lavorativi. Riceverai una notifica una volta approvata."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "We beoordelen uw claim binnen 1-3 werkdagen. U krijgt bericht als deze is goedgekeurd."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprawdzimy Twoje zgłoszenie w ciągu 1-3 dni roboczych. Zostaniesz powiadomiony o jego zatwierdzeniu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Analisaremos sua solicitação em 1 a 3 dias úteis. Você será notificado quando for aprovada."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Vom revizui revendicarea în 1-3 zile lucrătoare. Vei fi notificat când este aprobată."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы рассмотрим вашу заявку в течение 1-3 рабочих дней. Вы получите уведомление после одобрения."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi kommer att granska ditt anspråk inom 1-3 arbetsdagar. Du meddelas när det har godkänts."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Talebinizi 1-3 iş günü içinde inceleyeceğiz. Onaylandığında bilgilendirileceksiniz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ми розглянемо ваш запит протягом 1-3 робочих днів. Ви отримаєте сповіщення після його схвалення."
          }
        }
      }
    },
