    "tos_account_1": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Jste zodpovědní za zachování důvěrnosti vašich přihlašovacích údajů a aktivit na vašem účtu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du er ansvarlig for at opretholde fortroligheden af dine loginoplysninger og aktivitet på din konto."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie sind für die Wahrung der Vertraulichkeit Ihrer Zugangsdaten und der Aktivitäten in Ihrem Konto verantwortlich."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are responsible for maintaining the confidentiality of your credentials and activity under your account."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eres responsable de mantener la confidencialidad de tus credenciales y de la actividad en tu cuenta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous êtes responsable du maintien de la confidentialité de vos identifiants et de l'activité sur votre compte."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ön felelős a hitelesítő adatai és a fiókja alatti tevékenységek titkosságának megőrzéséért."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei responsabile del mantenimento della riservatezza delle tue credenziali e dell'attività sul tuo account."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "U bent verantwoordelijk voor het vertrouwelijk houden van uw inloggegevens en activiteiten onder uw account."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jesteś odpowiedzialny za zachowanie poufności swoich danych logowania oraz aktywność na swoim koncie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você é responsável por manter a confidencialidade de suas credenciais e atividades em sua conta."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Ești responsabil pentru menținerea confidențialității acreditărilor tale și a activității din contul tău."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы несете ответственность за сохранение конфиденциальности ваших учетных данных и активности в вашем аккаунте."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du är ansvarig för att upprätthålla sekretessen för dina inloggningsuppgifter och aktiviteter på ditt konto."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kimlik bilgilerinizin ve hesabınız altındaki faaliyetlerin gizliliğini korumaktan siz sorumlusunuz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви несете відповідальність за збереження конфіденційності ваших облікових даних та активності у вашому обліковому записі."
          }
        }
      }
    },
    "tos_account_2": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Účty, které porušují tyto podmínky, platné zákony nebo požadavky na bezpečnost platformy, můžeme pozastavit nebo zrušit."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi kan suspendere eller afslutte konti, der overtræder disse vilkår, gældende lov eller platformens sikkerhedskrav."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir können Konten sperren oder kündigen, die gegen diese Bedingungen, geltendes Recht oder Sicherheitsanforderungen der Plattform verstoßen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We may suspend or terminate accounts that violate these terms, applicable law, or platform safety requirements."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Podemos suspender o cancelar las cuentas que violen estos términos, la ley aplicable o los requisitos de seguridad de la plataforma."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous pouvons suspendre ou fermer les comptes qui violent ces conditions, la loi applicable ou les exigences de sécurité de la plateforme."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Felfüggeszthetjük vagy megszüntethetjük azokat a fiókokat, amelyek megsértik ezeket a feltételeket, a vonatkozó jogszabályokat vagy a platform biztonsági követelményeit."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Possiamo sospendere o chiudere gli account che violano questi termini, la legge applicabile o i requisiti di sicurezza della piattaforma."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "We kunnen accounts opschorten of beëindigen die deze voorwaarden, de toepasselijke wetgeving of platformveiligheidseisen schenden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Możemy zawiesić lub usunąć konta, które naruszają niniejszy regulamin, obowiązujące prawo lub wymogi bezpieczeństwa platformy."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Podemos suspender ou encerrar contas que violarem estes termos, a lei aplicável ou os requisitos de segurança da plataforma."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Putem suspenda sau închide conturile care încalcă acești termeni, legile aplicabile sau cerințele de siguranță ale platformei."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы можем приостановить или закрыть аккаунты, нарушающие эти условия, законодательство или требования безопасности."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi kan stänga av eller avsluta konton som bryter mot dessa villkor, tillämplig lagstiftning eller plattformens säkerhetskrav."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu şartları, yürürlükteki yasaları veya platform güvenlik gereksinimlerini ihlal eden hesapları askıya alabilir veya feshedebiliriz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ми можемо призупинити або закрити облікові записи, які порушують ці умови, чинне законодавство або вимоги щодо безпеки платформи."
          }
        }
      }
    },
