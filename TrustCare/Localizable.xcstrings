    },
    "pp_data_sharing_2" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vi kan videregive oplysninger, når det kræves ved lov eller for at beskytte brugere og platformens integritet."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir können Informationen offenlegen, wenn dies gesetzlich erforderlich ist oder zum Schutz von Nutzern und Plattformintegrität."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We may disclose information when required by law, regulation, legal process, or to protect users and platform integrity."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We kunnen informatie openbaar maken wanneer dit wettelijk verplicht is of om gebruikers en platformintegriteit te beschermen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Możemy ujawnić informacje, gdy wymagają tego przepisy prawa lub dla ochrony użytkowników i integralności platformy."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yasal yükümlülük, resmi talep veya kullanıcı güvenliğini koruma amacıyla bilgi açıklayabiliriz."
          }
        }
      }
    },
    "pp_data_sharing_3" : {
