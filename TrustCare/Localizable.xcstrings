    "pp_security_1" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vi anvender tekniske og organisatoriske foranstaltninger for at beskytte data mod uautoriseret adgang og misbrug."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir setzen technische und organisatorische Maßnahmen ein, um Daten vor unbefugtem Zugriff und Missbrauch zu schützen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We apply technical and organizational safeguards designed to protect data against unauthorized access and misuse."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We nemen technische en organisatorische maatregelen om gegevens te beschermen tegen ongeautoriseerde toegang en misbruik."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stosujemy środki techniczne i organizacyjne, aby chronić dane przed nieuprawnionym dostępem i nadużyciem."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verileri yetkisiz erişim ve kötüye kullanıma karşı korumak için teknik ve organizasyonel önlemler uygularız."
          }
        }
      }
    },
    "pp_security_2" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Intet onlinesystem er fuldstændigt sikkert; vi overvåger og forbedrer løbende vores kontroller."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kein Onlinesystem ist vollständig sicher; wir überwachen und verbessern unsere Kontrollen fortlaufend."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No online system is completely secure; we continuously monitor and improve our controls."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geen online systeem is volledig veilig; we monitoren en verbeteren onze controles continu."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Żaden system online nie jest całkowicie bezpieczny; stale monitorujemy i ulepszamy zabezpieczenia."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hiçbir çevrim içi sistem tamamen güvenli değildir; kontrollerimizi sürekli izler ve iyileştiririz."
          }
        }
      }
    },
    "pp_security_3" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis en sikkerhedshændelse påvirker dine data, underretter vi dig og relevante myndigheder, når loven kræver det."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn ein Sicherheitsvorfall Ihre Daten betrifft, informieren wir Sie und Behörden, sofern gesetzlich erforderlich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If a security incident affects your data, we will notify you and regulators when legally required."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Als een beveiligingsincident je gegevens raakt, informeren we jou en toezichthouders wanneer dat wettelijk vereist is."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeśli incydent bezpieczeństwa wpłynie na Twoje dane, powiadomimy Cię oraz właściwe organy, gdy wymagają tego przepisy."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verilerinizi etkileyen bir güvenlik olayı yaşanırsa, yasal olarak gerektiğinde sizi ve ilgili kurumları bilgilendiririz."
          }
        }
      }
    },
