          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vragen over deze Voorwaarden kunnen naar support@trustcare.app worden gestuurd."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pytania dotyczące niniejszego Regulaminu można przesyłać na adres support@trustcare.app."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
