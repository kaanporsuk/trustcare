    "pp_rights_1": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "V závislosti na vašem regionu můžete mít právo na přístup, opravu, export, omezení nebo vymazání vašich osobních údajů."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Afhængigt af din region kan du have ret til at få adgang til, rette, eksportere, begrænse eller slette dine personoplysninger."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Je nach Region haben Sie möglicherweise das Recht auf Auskunft, Berichtigung, Export, Einschränkung oder Löschung Ihrer personenbezogenen Daten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Depending on your region, you may have rights to access, correct, export, restrict, or delete your personal data."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dependiendo de tu región, puedes tener derecho a acceder, corregir, exportar, restringir o eliminar tus datos personales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Selon votre région, vous pouvez avoir le droit d'accéder, corriger, exporter, restreindre ou supprimer vos données personnelles."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A régiójától függően joga lehet a személyes adataihoz való hozzáféréshez, azok helyesbítéséhez, exportálásához, korlátozásához vagy törléséhez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "A seconda della tua regione, potresti avere i diritti di accesso, correzione, esportazione, limitazione o eliminazione dei tuoi dati personali."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Afhankelijk van uw regio heeft u mogelijk het recht om uw persoonlijke gegevens in te zien, te corrigeren, te exporteren, te beperken of te verwijderen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "W zależności od regionu, możesz mieć prawo do dostępu, poprawiania, eksportowania, ograniczania lub usuwania swoich danych osobowych."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Dependendo da sua região, você pode ter o direito de acessar, corrigir, exportar, restringir ou excluir seus dados pessoais."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "În funcție de regiunea ta, poți avea drepturi de a accesa, corecta, exporta, restricționa sau șterge datele tale personale."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В зависимости от региона, у вас может быть право на доступ, изменение, экспорт или удаление данных."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Beroende på din region kan du ha rätt att få tillgång till, korrigera, exportera, begränsa eller radera dina personuppgifter."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bölgenize bağlı olarak kişisel verilerinize erişme, düzeltme, dışa aktarma, kısıtlama veya silme haklarına sahip olabilirsiniz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Залежно від вашого регіону ви можете мати права на доступ, виправлення, експорт, обмеження обробки або видалення ваших персональних даних."
          }
        }
      }
    },
    "pp_rights_2": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Informace v profilu můžete aktualizovat přímo v aplikaci nebo požádat o podporu při akcích na úrovni účtu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kan opdatere profiloplysninger direkte i appen eller anmode om support til handlinger på kontoniveau."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie können Profilinformationen direkt in der App aktualisieren oder Support für Aktionen auf Kontoebene anfordern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can update profile information directly in the app or request support for account-level actions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes actualizar la información de tu perfil directamente en la app o solicitar soporte para acciones a nivel de cuenta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez mettre à jour les informations de profil directement dans l'application ou demander de l'aide pour les actions liées au compte."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Frissítheti a profilinformációkat közvetlenül az alkalmazásban, vagy kérhet támogatást a fiókszintű műveletekhez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Puoi aggiornare le informazioni del profilo direttamente nell'app o richiedere assistenza per azioni a livello di account."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "U kunt profielinformatie direct in de app bijwerken of ondersteuning aanvragen voor acties op accountniveau."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Możesz zaktualizować informacje o profilu bezpośrednio w aplikacji lub poprosić o pomoc przy operacjach na poziomie konta."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você pode atualizar as informações do perfil diretamente no app ou solicitar suporte para ações na conta."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Poți actualiza informațiile de profil direct din aplicație sau poți solicita asistență pentru acțiuni la nivel de cont."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы можете обновить профиль в приложении или запросить удаление аккаунта через поддержку."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kan uppdatera profilinformation direkt i appen eller begära support för åtgärder på kontonivå."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Profil bilgilerini doğrudan uygulamadan güncelleyebilir veya hesap düzeyindeki işlemler için destek isteyebilirsiniz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви можете оновити інформацію профілю безпосередньо в додатку або звернутися до служби підтримки для дій з обліковим записом."
          }
        }
      }
    },
    "pp_rights_3": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Můžete vznést námitku proti určitému zpracování, pokud to umožňují místní zákony."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kan gøre indsigelse mod visse behandlinger, hvor det er gældende under lokal lovgivning."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie können bestimmten Verarbeitungen widersprechen, sofern dies nach lokalem Recht zulässig ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You may object to certain processing where applicable under local law."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes oponerte a ciertos procesamientos cuando sea aplicable bajo la ley local."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez vous opposer à certains traitements lorsque la loi locale le permet."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A helyi törvényeknek megfelelően tiltakozhat bizonyos adatkezelések ellen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Puoi opporti a determinati trattamenti ove applicabile ai sensi della legge locale."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "U kunt bezwaar maken tegen bepaalde verwerkingen waar van toepassing onder de lokale wetgeving."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Możesz sprzeciwić się pewnym rodzajom przetwarzania danych, o ile pozwalają na to przepisy lokalne."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você pode se opor a determinados processamentos quando aplicável pela lei local."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Poți obiecta la anumite procesări, acolo unde este aplicabil conform legislației locale."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы можете возразить против обработки данных, если это предусмотрено местным законодательством."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kan invända mot viss behandling i tillämpliga fall enligt lokal lagstiftning."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yerel yasalar uyarınca geçerli olduğu durumlarda belirli işlemlere itiraz edebilirsiniz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви можете заперечити проти певної обробки даних, якщо це передбачено місцевим законодавством."
          }
        }
      }
    },
    "pp_rights_4": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro uplatnění svých práv kontaktujte support@trustcare.app a my vám odpovíme v zákonem stanovené lhůtě."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "For at udøve dine rettigheder, kontakt support@trustcare.app, og vi vil svare inden for den lovpligtige tidsramme."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Um Ihre Rechte auszuüben, kontaktieren Sie support@trustcare.app. Wir werden innerhalb der gesetzlich vorgeschriebenen Frist antworten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To exercise your rights, contact support@trustcare.app and we will respond within the legally required timeframe."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Para ejercer tus derechos, contáctanos en support@trustcare.app y responderemos dentro del plazo legalmente requerido."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour exercer vos droits, contactez support@trustcare.app et nous vous répondrons dans les délais légaux requis."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A jogai gyakorlásához lépjen kapcsolatba a support@trustcare.app címmel, és a törvényben előírt időkereten belül válaszolunk."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per esercitare i tuoi diritti, contatta support@trustcare.app e risponderemo entro i tempi previsti dalla legge."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Om uw rechten uit te oefenen, neem contact op via support@trustcare.app en wij reageren binnen de wettelijk vereiste termijn."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aby skorzystać ze swoich praw, skontaktuj się z support@trustcare.app, a odpowiemy w prawnie wymaganym czasie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Para exercer seus direitos, contate support@trustcare.app e responderemos dentro do prazo legal exigido."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Pentru a-ți exercita drepturile, contactează support@trustcare.app și îți vom răspunde în termenul prevăzut de lege."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Свяжитесь с support@trustcare.app для реализации своих прав."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "För att utöva dina rättigheter, kontakta support@trustcare.app så svarar vi inom den tidsram som lagen kräver."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Haklarınızı kullanmak için support@trustcare.app adresiyle iletişime geçin, yasal olarak gerekli süre içinde yanıt vereceğiz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Щоб скористатися своїми правами, напишіть на support@trustcare.app, і ми відповімо в межах встановленого законом терміну."
          }
        }
      }
    },
