    "find_state_clear_filters_body": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vymažte jeden nebo více filtrů nebo posuňte mapu, abyste rozšířili výsledky."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ryd en eller flere filtre, eller flyt kortet for at udvide resultaterne."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Löschen Sie einen oder mehrere Filter, oder verschieben Sie die Karte, um die Ergebnisse zu erweitern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clear one or more filters, or move the map to expand results."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Borra uno o más filtros o mueve el mapa para expandir los resultados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Effacez un ou plusieurs filtres, ou déplacez la carte pour élargir les résultats."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Töröljön egy vagy több szűrőt, vagy mozgassa a térképet a találatok bővítéséhez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancella uno o più filtri, oppure sposta la mappa per espandere i risultati."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wis een of meer filters, of verplaats de kaart om resultaten uit te breiden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyczyść jeden lub więcej filtrów albo przesuń mapę, aby rozszerzyć wyniki."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Limpe um ou mais filtros, ou mova o mapa para expandir os resultados."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Șterge unul sau mai multe filtre, sau mută harta pentru a extinde rezultatele."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Очистите один или несколько фильтров или переместите карту."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Rensa ett eller flera filter, eller flytta kartan för att utöka resultaten."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sonuçları genişletmek için bir veya daha fazla filtreyi temizleyin veya haritayı kaydırın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Очистіть один або кілька фільтрів, або перемістіть карту, щоб розширити результати."
          }
        }
      }
    },
