    },
    "tos_contact_2": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pokračováním v používání služby potvrzujete, že jste si tyto Podmínky přečetli a souhlasíte s nimi."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ved at fortsætte med at bruge tjenesten, bekræfter du, at du har læst og accepteret disse vilkår."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durch die weitere Nutzung des Dienstes bestätigen Sie, dass Sie diese Bedingungen gelesen haben und ihnen zustimmen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "By continuing to use the service, you acknowledge that you have read and agreed to these Terms."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al continuar usando el servicio, reconoces que has leído y aceptas estos Términos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "En continuant à utiliser le service, vous reconnaissez avoir lu et accepté ces Conditions."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A szolgáltatás további használatával tudomásul veszi, hogy elolvasta és elfogadta a jelen Feltételeket."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Continuando a utilizzare il servizio, riconosci di aver letto e accettato questi Termini."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Door de service te blijven gebruiken, bevestigt u dat u deze Voorwaarden hebt gelezen en ermee instemt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Korzystając dalej z usługi, potwierdzasz, że zapoznałeś się z niniejszym Regulaminem i go akceptujesz."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ao continuar usando o serviço, você reconhece que leu e concordou com estes Termos."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Continuând să folosești serviciul, recunoști că ai citit și ai acceptat acești Termeni."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Продолжая использовать сервис, вы подтверждаете, что прочитали и согласны с этими Условиями."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Genom att fortsätta använda tjänsten bekräftar du att du har läst och godkänt dessa villkor."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hizmeti kullanmaya devam ederek, bu Şartları okuduğunuzu ve kabul ettiğinizi onaylarsınız."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Продовжуючи користуватися сервісом, ви підтверджуєте, що прочитали та погоджуєтесь із цими Умовами."
          }
        }
      }
    },
