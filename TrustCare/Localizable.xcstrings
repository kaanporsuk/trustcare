    "tos_review_1" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anmeldelser skal afspejle ægte førsthåndsoplevelser og må ikke indeholde chikane, hadtale eller ulovligt indhold."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bewertungen müssen echte Erfahrungen aus erster Hand widerspiegeln und dürfen keine Belästigung, Hassrede oder rechtswidrige Inhalte enthalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reviews must reflect genuine, firsthand experiences and must not include harassment, hate speech, or unlawful content."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beoordelingen moeten echte ervaringen uit eerste hand weergeven en mogen geen intimidatie, haatzaaien of onwettige inhoud bevatten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opinie muszą odzwierciedlać rzeczywiste doświadczenia z pierwszej ręki i nie mogą zawierać nękania, mowy nienawiści ani treści niezgodnych z prawem."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Değerlendirmeler gerçek, birinci el deneyimlere dayanmalı; taciz, nefret söylemi veya hukuka aykırı içerik içermemelidir."
          }
        }
      }
    },
    "tos_review_2" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ved at indsende indhold giver du TrustCare licens til at hoste, vise og moderere indholdet for at drive tjenesten."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mit dem Einreichen von Inhalten erteilen Sie TrustCare eine Lizenz, diese für den Betrieb zu hosten, darzustellen und zu moderieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "By submitting content, you grant TrustCare a license to host, display, and moderate that content for service operation."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Door content in te dienen, verleen je TrustCare een licentie om die content te hosten, tonen en modereren voor de dienstverlening."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przesyłając treści, udzielasz TrustCare licencji na ich hostowanie, wyświetlanie i moderację na potrzeby działania usługi."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "İçerik göndererek, hizmetin işletimi için bu içeriği barındırma, gösterme ve moderasyon lisansını TrustCare'e verirsiniz."
          }
        }
      }
    },
    "tos_review_3" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vi kan fjerne, begrænse eller markere indhold, der overtræder politikker, juridiske krav eller sikkerhedsstandarder."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir können Inhalte entfernen, einschränken oder markieren, wenn sie Richtlinien, rechtliche Vorgaben oder Sicherheitsstandards verletzen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We may remove, limit, or flag content that violates policy, legal obligations, or trust and safety standards."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We kunnen content verwijderen, beperken of markeren die beleid, wettelijke verplichtingen of veiligheidsnormen schendt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Możemy usuwać, ograniczać lub oznaczać treści naruszające zasady, wymogi prawne lub standardy bezpieczeństwa."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Politika, yasal yükümlülük veya güvenlik standartlarını ihlal eden içerikleri kaldırabilir, sınırlayabilir veya işaretleyebiliriz."
          }
        }
      }
    },
