    "discover_error_providers_unavailable_body": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Možná došlo k chybě připojení. Zkuste to prosím znovu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Der kan være et forbindelsesproblem. Prøv venligst igen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es liegt möglicherweise ein Verbindungsproblem vor. Bitte versuchen Sie es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "There may be a connection issue. Please try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puede haber un problema de conexión. Por favor, inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il y a peut-être un problème de connexion. Veuillez réessayer."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Kapcsolódási hiba léphetett fel. Kérjük, próbálja újra."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Potrebbe esserci un problema di connessione. Riprova."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er is mogelijk een verbindingsprobleem. Probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Może występować problem z połączeniem. Spróbuj ponownie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pode haver um problema de conexão. Tente novamente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Ar putea exista o problemă de conexiune. Te rugăm să încerci din nou."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Возможно, проблема с подключением. Пожалуйста, попробуйте еще раз."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det kan vara ett anslutningsproblem. Vänligen försök igen."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bağlantı sorunu olabilir. Lütfen tekrar deneyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Можливо, виникла проблема зі з'єднанням. Будь ласка, спробуйте ще раз."
          }
        }
      }
    },
