            "value": "Las preguntas sobre estos Términos pueden enviarse a support@trustcare.app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les questions concernant ces Conditions peuvent être envoyées à support@trustcare.app."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A Feltételekkel kapcsolatos kérdéseket a support@trustcare.app címre lehet elküldeni."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
