          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Întrebările referitoare la acești Termeni pot fi trimise la support@trustcare.app."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
