          "stringUnit": {
            "state": "translated",
            "value": "Dit is geen medisch advies. Raadpleeg altijd een zorgprofessional."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To nie jest porada medyczna. Zawsze konsultuj się z lekarzem."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto não é um conselho médico. Consulte sempre um profissional de saúde."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Acesta nu este un sfat medical. Consultă întotdeauna un medic."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это не медицинский совет. Всегда консультируйтесь с врачом."
