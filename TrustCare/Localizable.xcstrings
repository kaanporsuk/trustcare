    "tos_dispute_1": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tyto Podmínky se řídí platnými zákony jurisdikce, ve které je usazen provozovatel služby, pokud místní kogentní právo nestanoví jinak."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Disse vilkår er underlagt gældende love i den jurisdiktion, hvor tjenesteudbyderen er etableret, medmindre lokal ufravigelig lovgivning bestemmer andet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Bedingungen unterliegen den geltenden Gesetzen der Gerichtsbarkeit, in der der Dienstbetreiber ansässig ist, sofern zwingendes lokales Recht nichts anderes vorschreibt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These Terms are governed by applicable laws of the jurisdiction where the service operator is established, unless local mandatory law provides otherwise."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estos Términos se rigen por las leyes aplicables de la jurisdicción donde está establecido el operador del servicio, a menos que la ley local obligatoria disponga lo contrario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ces conditions sont régies par les lois applicables de la juridiction où l'opérateur du service est établi, sauf disposition contraire de la loi locale impérative."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ezekre a Feltételekre a szolgáltató székhelye szerinti joghatóság alkalmazandó törvényei az irányadóak, kivéve, ha a helyi kötelező erejű jogszabály másként rendelkezik."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questi Termini sono regolati dalle leggi applicabili della giurisdizione in cui è stabilito l'operatore del servizio, a meno che la legge locale inderogabile non disponga diversamente."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze Voorwaarden worden beheerst door de toepasselijke wetten van het rechtsgebied waar de servicebeheerder is gevestigd, tenzij dwingend lokaal recht anders bepaalt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Niniejszy Regulamin podlega przepisom prawa właściwym dla siedziby operatora usługi, o ile obowiązujące przepisy lokalne nie stanowią inaczej."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Estes Termos são regidos pelas leis aplicáveis da jurisdição onde o operador do serviço está estabelecido, a menos que a lei local obrigatória exija o contrário."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Acești Termeni sunt guvernați de legile aplicabile din jurisdicția unde este stabilit operatorul serviciului, cu excepția cazului în care legislația locală obligatorie prevede altfel."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эти Условия регулируются законами юрисдикции оператора сервиса, если местное законодательство не требует иного."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dessa villkor styrs av tillämpliga lagar i den jurisdiktion där tjänsteoperatören är etablerad, såvida inte tvingande lokal lag föreskriver något annat."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yerel emredici hukuk aksini öngörmedikçe, bu Şartlar, hizmet operatörünün bulunduğu yargı bölgesinin geçerli yasalarına tabidir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ці Умови регулюються чинним законодавством юрисдикції, де зареєстровано оператора сервісу, якщо інше не передбачено місцевим обов'язковим законодавством."
          }
        }
      }
    },
    "tos_dispute_2": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Před zahájením formálního řízení souhlasíte s tím, že nás v dobré víře kontaktujete a pokusíte se o neformální vyřešení sporu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Før du indleder formelle retssager, accepterer du at kontakte os i god tro for at søge en uformel løsning."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bevor Sie ein formelles Verfahren einleiten, erklären Sie sich damit einverstanden, uns in gutem Glauben zu kontaktieren, um eine informelle Lösung zu finden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Before initiating formal proceedings, you agree to contact us in good faith to seek an informal resolution."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Antes de iniciar un procedimiento formal, aceptas comunicarte con nosotros de buena fe para buscar una resolución informal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Avant d'entamer une procédure formelle, vous acceptez de nous contacter de bonne foi pour rechercher une résolution à l'amiable."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A hivatalos eljárás megindítása előtt vállalja, hogy jóhiszeműen felveszi velünk a kapcsolatot az informális megoldás érdekében."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Prima di avviare procedimenti formali, accetti di contattarci in buona fede per cercare una risoluzione informale."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voordat u een formele procedure start, gaat u ermee akkoord om in goed vertrouwen contact met ons op te nemen voor een informele oplossing."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przed wszczęciem oficjalnego postępowania zgadzasz się skontaktować z nami w dobrej wierze w celu nieformalnego rozwiązania problemu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Antes de iniciar procedimentos formais, você concorda em nos contatar de boa-fé para buscar uma resolução informal."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Înainte de a iniția proceduri formale, ești de acord să ne contactezi cu bună-credință pentru a căuta o rezolvare informală."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перед инициированием официальных разбирательств вы соглашаетесь связаться с нами для досудебного урегулирования."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Innan du inleder ett formellt förfarande godkänner du att kontakta oss i god tro för att försöka hitta en informell lösning."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Resmi işlemlere başlamadan önce, gayri resmi bir çözüm aramak için iyi niyetle bizimle iletişime geçmeyi kabul edersiniz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Перш ніж ініціювати офіційні процедури, ви погоджуєтеся добросовісно зв'язатися з нами для пошуку неофіційного рішення."
          }
        }
      }
    },
