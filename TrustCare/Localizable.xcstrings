    "find_state_growing_body": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pokrytí se v této oblasti rozšiřuje. Zkuste prozatím nedaleké město."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dækningen udvides i dette område. Prøv en nærliggende by for nu."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Abdeckung in diesem Bereich wird erweitert. Versuchen Sie es vorerst mit einer nahegelegenen Stadt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We are onboarding providers in this region. Try a nearby city in the meantime."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cobertura se está expandiendo en esta área. Intenta en una ciudad cercana por ahora."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La couverture s'étend dans cette zone. Essayez une ville voisine pour le moment."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A lefedettség bővül ezen a területen. Egyelőre próbáljon meg egy közeli várost."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La copertura si sta espandendo in quest'area. Prova in una città vicina per ora."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De dekking breidt zich uit in dit gebied. Probeer voor nu een nabijgelegen stad."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zasięg w tej okolicy się powiększa. Spróbuj na razie w pobliskim mieście."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A cobertura está se expandindo nesta área. Tente uma cidade próxima por enquanto."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Acoperirea se extinde în această zonă. Încearcă într-un oraș din apropiere deocamdată."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В этом районе база пополняется. Попробуйте соседний город."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Täckningen utökas i detta område. Prova en närliggande stad så länge."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kapsam bu bölgede genişliyor. Şimdilik yakındaki bir şehri deneyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Покриття в цьому районі розширюється. Поки що спробуйте сусіднє місто."
          }
        }
      }
    },
