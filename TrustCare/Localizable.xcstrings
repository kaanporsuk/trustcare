          "stringUnit": {
            "state": "translated",
            "value": "Der gives ingen diagnose eller behandling; kun vejledning."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es wird keine Diagnose oder Behandlung bereitgestellt; nur Orientierung."
          }
        },
