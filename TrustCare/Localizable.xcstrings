    "tos_ip_1" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alt platformindhold, branding og software tilhører TrustCare eller er licenseret til os, medmindre andet er angivet."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plattforminhalte, Marken und Software gehören TrustCare oder sind entsprechend lizenziert, sofern nicht anders angegeben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All platform content, branding, and software are owned by TrustCare or licensed to us, unless otherwise stated."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle platforminhoud, branding en software zijn eigendom van TrustCare of aan ons gelicentieerd, tenzij anders vermeld."
          }
