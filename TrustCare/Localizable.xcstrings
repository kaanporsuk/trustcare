    "pp_cookies_1": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Naše webové rozhraní může používat soubory cookie a místní úložiště k zajištění bezpečnosti relací a zlepšení výkonu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vores weboverflader kan bruge cookies og lokal lagring for at holde sessioner sikre og forbedre ydeevnen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Unsere Web-Oberflächen verwenden möglicherweise Cookies und lokalen Speicher, um Sitzungen sicher zu halten und die Leistung zu verbessern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Our web surfaces may use cookies and local storage to keep sessions secure and improve performance."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Nuestras plataformas web pueden utilizar cookies y almacenamiento local para mantener seguras las sesiones y mejorar el rendimiento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nos interfaces web peuvent utiliser des cookies et le stockage local pour sécuriser les sessions et améliorer les performances."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A webes felületeink cookie-kat és helyi tárolást használhatnak a munkamenetek biztonságának megőrzése és a teljesítmény javítása érdekében."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le nostre interfacce web possono utilizzare cookie e archiviazione locale per mantenere sicure le sessioni e migliorare le prestazioni."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Onze webdiensten kunnen cookies en lokale opslag gebruiken om sessies veilig te houden en prestaties te verbeteren."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nasze strony internetowe mogą używać plików cookie i pamięci lokalnej, aby zapewnić bezpieczeństwo sesji i poprawić wydajność."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nossas interfaces da web podem usar cookies e armazenamento local para manter as sessões seguras e melhorar o desempenho."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Serviciile noastre web pot utiliza cookie-uri și stocare locală pentru a menține sesiunile sigure și a îmbunătăți performanța."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Наши веб-сервисы могут использовать файлы cookie и локальное хранилище для безопасности и улучшения работы."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Våra webbplatser kan använda cookies och lokal lagring för att hålla sessioner säkra och förbättra prestandan."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Web yüzeylerimiz, oturumları güvende tutmak ve performansı artırmak için çerezleri ve yerel depolamayı kullanabilir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Наші веб-ресурси можуть використовувати файли cookie та локальне сховище для підтримки безпеки сеансів та покращення продуктивності."
          }
        }
      }
    },
    "pp_cookies_2": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Předvolby souborů cookie můžete spravovat v nastavení prohlížeče, ačkoli jejich zakázání může ovlivnit funkčnost."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kan styre cookie-præferencer i dine browserindstillinger, selvom deaktivering af dem kan påvirke funktionaliteten."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie können die Cookie-Einstellungen in Ihrem Browser verwalten, obwohl die Deaktivierung die Funktionalität beeinträchtigen kann."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can control cookie preferences in your browser settings, though disabling them may affect functionality."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes controlar las preferencias de cookies en la configuración de tu navegador, aunque desactivarlas puede afectar la funcionalidad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez contrôler les préférences de cookies dans les paramètres de votre navigateur, bien que leur désactivation puisse affecter la fonctionnalité."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A cookie-k beállításait a böngésző beállításaiban kezelheti, bár a letiltásuk befolyásolhatja a funkcionalitást."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Puoi controllare le preferenze sui cookie nelle impostazioni del tuo browser, anche se disabilitarli potrebbe influire sulle funzionalità."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "U kunt cookievoorkeuren beheren in uw browserinstellingen, hoewel het uitschakelen ervan de functionaliteit kan beïnvloeden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Możesz kontrolować preferencje dotyczące plików cookie w ustawieniach przeglądarki, jednak ich wyłączenie może wpłynąć na funkcjonalność."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você pode controlar as preferências de cookies nas configurações do seu navegador, embora desativá-los possa afetar a funcionalidade."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Poți controla preferințele pentru cookie-uri din setările browserului, deși dezactivarea lor poate afecta funcționalitatea."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы можете управлять cookie в настройках браузера, но их отключение может повлиять на функциональность."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kan styra cookie-inställningar i din webbläsare, men inaktivering av dem kan påverka funktionaliteten."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Çerez tercihlerini tarayıcı ayarlarınızdan kontrol edebilirsiniz ancak bunları devre dışı bırakmak işlevselliği etkileyebilir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви можете керувати налаштуваннями cookie у своєму браузері, але їх вимкнення може вплинути на функціональність."
          }
        }
      }
    },
    "pp_cookies_3": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Analytické soubory cookie se používají v souhrnné podobě k pochopení trendů používání a vylepšení služby."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Analyse-cookies bruges i aggregeret form for at forstå brugstendenser og forbedre tjenesten."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Analyse-Cookies werden in aggregierter Form verwendet, um Nutzungstrends zu verstehen und den Service zu verbessern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Analytics cookies are used in aggregate form to understand usage trends and improve the service."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las cookies analíticas se utilizan de forma agregada para entender las tendencias de uso y mejorar el servicio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les cookies analytiques sont utilisés sous forme agrégée pour comprendre les tendances d'utilisation et améliorer le service."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az analitikai cookie-kat összesített formában használjuk a használati trendek megértése és a szolgáltatás javítása érdekében."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I cookie analitici vengono utilizzati in forma aggregata per comprendere le tendenze di utilizzo e migliorare il servizio."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Analytische cookies worden in geaggregeerde vorm gebruikt om gebruikstrends te begrijpen en de service te verbeteren."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Analityczne pliki cookie są używane w formie zagregowanej w celu zrozumienia trendów użytkowania i ulepszania usługi."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Cookies de análise são usados de forma agregada para entender tendências de uso e melhorar o serviço."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Cookie-urile de analiză sunt utilizate în formă agregată pentru a înțelege tendințele de utilizare și a îmbunătăți serviciul."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Аналитические cookie используются в агрегированном виде для улучшения сервиса."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Analys-cookies används i samlad form för att förstå användningstrender och förbättra tjänsten."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Analitik çerezleri, kullanım eğilimlerini anlamak ve hizmeti iyileştirmek için toplu biçimde kullanılır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Аналітичні файли cookie використовуються в агрегованому вигляді для розуміння тенденцій використання та покращення сервісу."
          }
        }
      }
    },
