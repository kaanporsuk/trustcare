    "pp_security_1": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Uplatňujeme technická a organizační opatření určená k ochraně údajů před neoprávněným přístupem a zneužitím."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi anvender tekniske og organisatoriske sikkerhedsforanstaltninger, der er designet til at beskytte data mod uautoriseret adgang og misbrug."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir wenden technische und organisatorische Sicherheitsmaßnahmen an, um Daten vor unbefugtem Zugriff und Missbrauch zu schützen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We apply technical and organizational safeguards designed to protect data against unauthorized access and misuse."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplicamos medidas de seguridad técnicas y organizativas diseñadas para proteger los datos contra el acceso no autorizado y el mal uso."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous appliquons des mesures de sécurité techniques et organisationnelles pour protéger les données contre l'accès non autorisé et l'utilisation abusive."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Olyan technikai és szervezési biztosítékokat alkalmazunk, amelyek célja az adatok védelme a jogosulatlan hozzáférés és visszaélés ellen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Applichiamo misure di salvaguardia tecniche e organizzative progettate per proteggere i dati da accessi non autorizzati e usi impropri."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wij passen technische en organisatorische veiligheidsmaatregelen toe die zijn ontworpen om gegevens te beschermen tegen ongeoorloofde toegang en misbruik."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stosujemy techniczne i organizacyjne zabezpieczenia, aby chronić dane przed nieautoryzowanym dostępem i nadużyciem."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplicamos salvaguardas técnicas e organizacionais projetadas para proteger dados contra acesso não autorizado e uso indevido."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplicăm măsuri de protecție tehnice și organizaționale menite să protejeze datele împotriva accesului neautorizat și a utilizării abuzive."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы применяем меры защиты данных от несанкционированного доступа."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi tillämpar tekniska och organisatoriska skyddsåtgärder utformade för att skydda data mot obehörig åtkomst och missbruk."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Verileri yetkisiz erişime ve kötüye kullanıma karşı korumak için tasarlanmış teknik ve organizasyonel önlemler uyguluyoruz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ми застосовуємо технічні та організаційні заходи для захисту даних від несанкціонованого доступу та неправомірного використання."
          }
        }
      }
    },
    "pp_security_2": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Žádný online systém není zcela bezpečný; naše kontroly neustále sledujeme a vylepšujeme."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Intet online system er fuldstændig sikkert; vi overvåger og forbedrer løbende vores kontroller."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kein Online-System ist absolut sicher; wir überwachen und verbessern unsere Kontrollmechanismen kontinuierlich."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No online system is completely secure; we continuously monitor and improve our controls."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ningún sistema en línea es completamente seguro; monitoreamos y mejoramos nuestros controles continuamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun système en ligne n'est totalement sécurisé ; nous surveillons et améliorons continuellement nos contrôles."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nincs teljesen biztonságos online rendszer; folyamatosan figyeljük és fejlesztjük ellenőrzéseinket."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun sistema online è completamente sicuro; monitoriamo e miglioriamo continuamente i nostri controlli."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geen enkel onlinesysteem is volledig veilig; we monitoren en verbeteren voortdurend onze controles."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Żaden system online nie jest w pełni bezpieczny; stale monitorujemy i ulepszamy nasze mechanizmy kontrolne."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum sistema online é completamente seguro; monitoramos e melhoramos continuamente nossos controles."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Niciun sistem online nu este complet sigur; monitorizăm și ne îmbunătățim în permanență controalele."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ни одна система не безопасна на 100%; мы постоянно улучшаем наши средства контроля."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Inget onlinesystem är helt säkert; vi övervakar och förbättrar kontinuerligt våra kontroller."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiçbir çevrimiçi sistem tamamen güvenli değildir; kontrollerimizi sürekli olarak izliyor ve iyileştiriyoruz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Жодна онлайн-система не є абсолютно безпечною; ми постійно моніторимо та вдосконалюємо наші заходи контролю."
          }
        }
      }
    },
    "pp_security_3": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pokud bezpečnostní incident ovlivní vaše data, upozorníme vás i regulační orgány, pokud to vyžaduje zákon."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvis en sikkerhedshændelse påvirker dine data, vil vi underrette dig og tilsynsmyndighederne, når det er lovmæssigt krævet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn ein Sicherheitsvorfall Ihre Daten betrifft, werden wir Sie und die Aufsichtsbehörden benachrichtigen, sofern dies gesetzlich vorgeschrieben ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If a security incident affects your data, we will notify you and regulators when legally required."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si un incidente de seguridad afecta a tus datos, te notificaremos a ti y a los reguladores cuando la ley lo exija."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si un incident de sécurité affecte vos données, nous vous en informerons ainsi que les autorités de régulation lorsque la loi l'exige."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ha egy biztonsági incidens érinti az Ön adatait, értesítjük Önt és a szabályozó hatóságokat, amikor azt a törvény megköveteli."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se un incidente di sicurezza interessa i tuoi dati, informeremo te e le autorità competenti quando richiesto dalla legge."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als een beveiligingsincident uw gegevens treft, zullen wij u en de toezichthouders informeren wanneer dit wettelijk verplicht is."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeśli incydent bezpieczeństwa wpłynie na Twoje dane, powiadomimy Ciebie i organy regulacyjne, gdy będzie to prawnie wymagane."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Se um incidente de segurança afetar seus dados, notificaremos você e os reguladores quando legalmente exigido."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Dacă un incident de securitate îți afectează datele, te vom notifica pe tine și autoritățile de reglementare atunci când legea o impune."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "При инцидентах безопасности мы уведомим вас и регуляторов, если этого требует закон."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Om en säkerhetsincident påverkar dina data kommer vi att meddela dig och tillsynsmyndigheter när lagen kräver det."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir güvenlik olayı verilerinizi etkilerse, yasal olarak gerektiğinde sizi ve düzenleyicileri bilgilendireceğiz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Якщо інцидент безпеки вплине на ваші дані, ми повідомимо вас і регуляторні органи, коли це вимагається законом."
          }
        }
      }
    },
