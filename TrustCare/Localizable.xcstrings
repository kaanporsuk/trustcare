    "error_duplicate_review": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro každého poskytovatele můžete odeslat pouze jednu recenzi denně."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kan kun indsende én anmeldelse pr. udbyder pr. dato."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie können pro Anbieter und Datum nur eine Bewertung abgeben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can only submit one review per provider per date."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo puedes enviar una reseña por proveedor y fecha."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous ne pouvez soumettre qu'un seul avis par professionnel et par date."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Szolgáltatónként és naponta csak egy értékelést küldhet be."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Puoi inviare solo una recensione per professionista per data."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "U kunt slechts één beoordeling per zorgaanbieder per datum indienen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Możesz przesłać tylko jedną opinię dla jednego dostawcy na dany dzień."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você só pode enviar uma avaliação por prestador por dia."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Poți trimite o singură recenzie per furnizor pe dată."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы можете оставить только один отзыв о специалисте за один день."
