    "pp_cookies_1" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vores webflader kan bruge cookies og lokal lagring for at sikre sessioner og forbedre ydeevne."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unsere Weboberflächen können Cookies und lokalen Speicher nutzen, um Sitzungen zu sichern und die Leistung zu verbessern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Our web surfaces may use cookies and local storage to keep sessions secure and improve performance."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Onze webomgevingen kunnen cookies en lokale opslag gebruiken om sessies veilig te houden en prestaties te verbeteren."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nasze powierzchnie webowe mogą używać plików cookie i pamięci lokalnej dla bezpieczeństwa sesji i poprawy wydajności."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Web yüzeylerimizde oturum güvenliği ve performans iyileştirmesi için çerezler ve yerel depolama kullanılabilir."
          }
        }
      }
    },
    "pp_cookies_2" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kan styre cookie-præferencer i browserindstillinger; deaktivering kan påvirke funktionalitet."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie können Cookie-Einstellungen in Ihrem Browser steuern; das Deaktivieren kann Funktionen beeinträchtigen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can control cookie preferences in your browser settings, though disabling them may affect functionality."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je kunt cookievoorkeuren beheren in je browserinstellingen; uitschakelen kan functionaliteit beperken."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preferencje cookie możesz kontrolować w ustawieniach przeglądarki; ich wyłączenie może ograniczyć działanie funkcji."
