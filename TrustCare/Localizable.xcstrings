    "pp_data_sharing_1" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vi deler data med tjenesteudbydere, der driver hosting, analyse, moderation og kommunikation."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir teilen Daten mit Dienstleistern für Hosting, Analytik, Moderation und Kommunikation."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We share data with service providers that operate hosting, analytics, moderation, and communication systems."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We delen gegevens met dienstverleners die hosting, analytics, moderatie en communicatie ondersteunen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Udostępniamy dane dostawcom usług obsługującym hosting, analitykę, moderację i komunikację."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verileri barındırma, analiz, moderasyon ve iletişim altyapısı sağlayan hizmet ortaklarımızla paylaşabiliriz."
          }
        }
