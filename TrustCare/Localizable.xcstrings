    "pp_data_collection_1" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vi indsamler kontodata såsom e-mail, navn, profilpræferencer og autentificeringsmetadata."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir erheben Kontodaten wie E-Mail, Name, Profileinstellungen und Authentifizierungsmetadaten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We collect account data such as email, name, profile preferences, and authentication metadata."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We verzamelen accountgegevens zoals e-mail, naam, profielvoorkeuren en authenticatiemetadata."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zbieramy dane konta, takie jak e-mail, imię i nazwisko, preferencje profilu oraz metadane uwierzytelniania."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "E-posta, ad, profil tercihleri ve kimlik doğrulama meta verileri gibi hesap bilgilerini toplarız."
          }
        }
      }
    },
    "pp_data_collection_2" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Når du sender anmeldelser, behandler vi vurderinger, kommentarer, valgfri medier og valgfri verifikationsmateriale."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bei Bewertungsabgaben verarbeiten wir Bewertungen, Kommentare, optionale Medien und optionale Verifizierungsnachweise."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When you submit reviews, we collect ratings, comments, optional media, and optional verification artifacts."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wanneer je beoordelingen indient, verwerken we ratings, opmerkingen, optionele media en optionele verificatiematerialen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przy dodawaniu opinii przetwarzamy oceny, komentarze, opcjonalne media i opcjonalne materiały weryfikacyjne."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Değerlendirme gönderdiğinizde puanlar, yorumlar, isteğe bağlı medya ve isteğe bağlı doğrulama belgeleri işlenir."
          }
        }
      }
    },
    "pp_data_collection_3" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vi kan behandle enheds- og brugsdata, herunder apphændelser, omtrentelig placering og diagnostik."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir können Geräte- und Nutzungsdaten verarbeiten, einschließlich App-Ereignissen, ungefährer Standortdaten und Diagnosedaten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We may process device and usage data including app events, approximate location, and diagnostics."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We kunnen apparaat- en gebruiksgegevens verwerken, inclusief appgebeurtenissen, geschatte locatie en diagnostiek."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Możemy przetwarzać dane urządzenia i użycia, w tym zdarzenia aplikacji, przybliżoną lokalizację i dane diagnostyczne."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uygulama olayları, yaklaşık konum ve tanılama verileri dahil cihaz ve kullanım verilerini işleyebiliriz."
          }
        }
      }
    },
    "pp_data_collection_4" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vi indsamler ikke bevidst følsomme sundhedsjournaler ud over de oplysninger, du selv vælger at indsende."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir erheben keine sensiblen Gesundheitsakten, außer den Informationen, die Sie aktiv einreichen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We do not intentionally collect sensitive health records beyond the information you choose to submit."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We verzamelen niet bewust gevoelige medische dossiers, behalve informatie die je zelf indient."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
