    "help_faq_a1": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Otevřete Hodnotit, vyberte poskytovatele a vyplňte formulář."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Åbn Bedøm, vælg en udbyder, og udfyld den guidede formular."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffnen Sie Bewerten, wählen Sie einen Anbieter und füllen Sie das angeleitete Formular aus."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Review, choose a provider, and complete the guided form."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre Reseñas, elige un proveedor y completa el formulario guiado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrez Évaluer, choisissez un professionnel et remplissez le formulaire guidé."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nyissa meg az Értékelést, válasszon egy szolgáltatót, és töltse ki az űrlapot."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apri Recensisci, scegli un professionista e completa il modulo guidato."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Beoordeling, kies een zorgaanbieder en vul het formulier in."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Otwórz sekcję Oceń, wybierz dostawcę i wypełnij formularz."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra Avaliar, escolha um prestador e preencha o formulário guiado."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Deschide Recenzii, alege un furnizor și completează formularul ghidat."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откройте 'Оценить', выберите специалиста и заполните форму."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Öppna Recensera, välj en vårdgivare och fyll i det guidade formuläret."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Değerlendir'i açın, bir sağlayıcı seçin ve yönlendirmeli formu doldurun."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Відкрийте 'Оцінити', виберіть спеціаліста та заповніть форму."
          }
        }
      }
    },
    "help_faq_a2": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Ano. Otevřete Moje recenze a klepněte na Upravit u své recenze."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ja. Åbn Mine anmeldelser og tryk på Rediger på din anmeldelse."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ja. Öffnen Sie Meine Bewertungen und tippen Sie bei Ihrer Bewertung auf Bearbeiten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Yes. Open My Reviews and tap Edit on your review."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sí. Abre Mis Reseñas y toca Editar en tu reseña."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Oui. Ouvrez Mes Avis et appuyez sur Modifier sur votre avis."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Igen. Nyissa meg az Értékeléseim menüpontot, és koppintson a Szerkesztés gombra az értékelésénél."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sì. Apri Le mie recensioni e tocca Modifica sulla tua recensione."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ja. Open Mijn Beoordelingen en tik op Bewerken bij uw beoordeling."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tak. Otwórz Moje opinie i dotknij Edytuj na swojej opinii."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sim. Abra Minhas Avaliações e toque em Editar na sua avaliação."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Da. Deschide Recenziile mele și apasă Editează pe recenzia ta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Да. Откройте 'Мои отзывы' и нажмите 'Изменить' на вашем отзыве."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ja. Öppna Mina recensioner och tryck på Redigera på din recension."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Evet. Değerlendirmelerim'i açın ve değerlendirmeniz üzerinde Düzenle'ye dokunun."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Так. Відкрийте 'Мої відгуки' та натисніть 'Редагувати' на своєму відгуку."
          }
        }
      }
    },
    "help_faq_a3": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Ověřeno znamená, že recenze prošla našimi kontrolami nebo obsahuje důkaz."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Verificeret betyder, at anmeldelsen har bestået vores tjek eller inkluderer understøttende bevis."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verifiziert bedeutet, dass die Bewertung unsere Prüfungen bestanden hat oder unterstützende Nachweise enthält."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Verified means the review passed our checks or includes supporting proof."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Verificado significa que la reseña pasó nuestros controles o incluye pruebas de respaldo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vérifié signifie que l'avis a passé nos contrôles ou inclut une preuve à l'appui."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az 'Ellenőrzött' azt jelenti, hogy az értékelés átment az ellenőrzéseinken, vagy tartalmaz bizonyító erejű dokumentumot."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Verificato significa che la recensione ha superato i nostri controlli o include prove a supporto."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geverifieerd betekent dat de beoordeling onze controles heeft doorstaan of bewijs bevat."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zweryfikowana oznacza, że opinia przeszła nasze testy lub zawiera dowód potwierdzający."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Verificado significa que a avaliação passou em nossas verificações ou inclui provas comprobatórias."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Verificat înseamnă că recenzia a trecut de verificările noastre sau include dovezi justificative."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверенный означает, что отзыв прошел нашу модерацию или содержит доказательства."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Verifierad innebär att recensionen har klarat våra kontroller eller inkluderar bevis."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Doğrulanmış, değerlendirmenin kontrollerimizden geçtiği veya destekleyici kanıt içerdiği anlamına gelir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Перевірений означає, що відгук пройшов наші перевірки або містить докази."
          }
        }
      }
    },
    "help_faq_a4": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Otevřete recenzi a klepněte na Nahlásit. Náš tým to zkontroluje."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Åbn anmeldelsen og tryk på Anmeld. Vores team vil gennemgå den."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffnen Sie die Bewertung und tippen Sie auf Melden. Unser Team wird sie überprüfen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open the review and tap Report. Our team will review it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre la reseña y toca Reportar. Nuestro equipo lo revisará."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrez l'avis et appuyez sur Signaler. Notre équipe l'examinera."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nyissa meg az értékelést, és koppintson a Jelentés gombra. Csapatunk felülvizsgálja."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apri la recensione e tocca Segnala. Il nostro team la esaminerà."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Open de beoordeling en tik op Melden. Ons team zal het bekijken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Otwórz opinię i dotknij Zgłoś. Nasz zespół ją sprawdzi."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra a avaliação e toque em Denunciar. Nossa equipe a analisará."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Deschide recenzia și apasă Raportează. Echipa noastră o va examina."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откройте отзыв и нажмите 'Пожаловаться'. Наша команда проверит его."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
