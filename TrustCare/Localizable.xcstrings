          }
        }
      }
    },
    "rehber_emergency_danger": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pokud jste vy nebo někdo jiný v nebezpečí, okamžitě volejte."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvis du eller andre er i fare, ring med det samme."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Sie oder eine andere Person in Gefahr sind, rufen Sie sofort an."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you or someone else is in danger, call immediately."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si tú u otra persona están en peligro, llama inmediatamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si vous ou quelqu'un d'autre êtes en danger, appelez immédiatement."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ha Ön vagy más veszélyben van, hívjon segítséget azonnal."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se tu o qualcun altro siete in pericolo, chiama immediatamente."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bel onmiddellijk als u of iemand anders in gevaar is."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeśli ty lub ktoś inny jesteście w niebezpieczeństwie, dzwoń natychmiast."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Se você ou outra pessoa estiver em perigo, ligue imediatamente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Dacă tu sau altcineva sunteți în pericol, sunați imediat."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если вы или кто-то другой в опасности, немедленно звоните в скорую."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Om du eller någon annan är i fara, ring omedelbart."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Siz veya başka biri tehlikedeyse hemen arayın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Якщо ви або хтось інший у небезпеці, телефонуйте негайно."
          }
        }
      }
    },
    "rehber_emergency_detected": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "🚨 Bylo zjištěno potenciální riziko stavu nouze. Okamžitě volejte 112."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "🚨 En potentiel nødsituation blev opdaget. Ring 112 med det samme."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "🚨 Ein potenzielles Notfallrisiko wurde erkannt. Bitte rufen Sie sofort 112 an."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🚨 A potential emergency risk was detected. Please call 112 immediately."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "🚨 Se detectó un riesgo potencial de emergencia. Llama al 112 inmediatamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "🚨 Un risque d'urgence potentiel a été détecté. Appelez immédiatement le 112."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "🚨 Potenciális vészhelyzeti kockázatot észleltünk. Kérjük, azonnal hívja a 112-t."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "🚨 È stato rilevato un potenziale rischio di emergenza. Chiama subito il 112."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "🚨 Er is een mogelijk noodrisico gedetecteerd. Bel direct 112."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "🚨 Wykryto potencjalne zagrożenie życia. Zadzwoń natychmiast pod numer 112."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "🚨 Um risco potencial de emergência foi detectado. Ligue para o 112 imediatamente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "🚨 A fost detectat un potențial risc de urgență. Sunați imediat la 112."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "🚨 Обнаружен риск для жизни. Немедленно звоните 112."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "🚨 En potentiell akut risk upptäcktes. Ring omedelbart 112."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "🚨 Olası bir acil durum riski tespit edildi. Lütfen hemen 112'yi arayın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "🚨 Виявлено потенційний ризик для життя. Негайно телефонуйте 112."
          }
        }
      }
    },
    "rehber_emergency_subtitle": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Okamžitě volejte 112"
          }
        },
        "da": {
