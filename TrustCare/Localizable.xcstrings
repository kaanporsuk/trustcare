    "tos_account_1" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du er ansvarlig for fortroligheden af dine loginoplysninger og aktiviteter under din konto."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie sind für die Vertraulichkeit Ihrer Zugangsdaten und Aktivitäten unter Ihrem Konto verantwortlich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You are responsible for maintaining the confidentiality of your credentials and activity under your account."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je bent verantwoordelijk voor de vertrouwelijkheid van je inloggegevens en activiteiten onder je account."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odpowiadasz za poufność danych logowania i aktywność wykonywaną w ramach Twojego konta."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hesap bilgilerinizin gizliliğini korumak ve hesabınız altındaki faaliyetlerden sorumlu olmak size aittir."
          }
        }
      }
    },
    "tos_account_2" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vi kan suspendere eller lukke konti, der overtræder disse vilkår, gældende lov eller platformens sikkerhedskrav."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir können Konten sperren oder beenden, die gegen diese Bedingungen, geltendes Recht oder Sicherheitsanforderungen verstoßen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We may suspend or terminate accounts that violate these terms, applicable law, or platform safety requirements."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We kunnen accounts opschorten of beëindigen die deze voorwaarden, toepasselijk recht of veiligheidsvereisten schenden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Możemy zawiesić lub zamknąć konta naruszające te Warunki, prawo lub wymogi bezpieczeństwa platformy."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu koşulları, yürürlükteki hukuku veya platform güvenlik kurallarını ihlal eden hesapları askıya alabilir veya kapatabiliriz."
          }
        }
      }
    },
