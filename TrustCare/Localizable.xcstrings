          }
        }
      }
    },
    "pp_cookies_3" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analytiske cookies bruges i aggregeret form til at forstå brugsmønstre og forbedre tjenesten."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analyse-Cookies werden aggregiert verwendet, um Nutzungstrends zu verstehen und den Dienst zu verbessern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
