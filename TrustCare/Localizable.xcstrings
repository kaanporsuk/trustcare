    "rehber_empty_state": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Podělte se o své příznaky, nasměruji vás na správnou specializaci."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Del dine symptomer, jeg vil guide dig til det rette speciale."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Teilen Sie Ihre Symptome mit, ich leite Sie an das richtige Fachgebiet weiter."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Share your symptoms, I'll guide you to the right specialty."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comparte tus síntomas, te orientaré hacia la especialidad correcta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Partagez vos symptômes, je vous guiderai vers la bonne spécialité."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ossza meg a tüneteit, és én a megfelelő szakterülethez irányítom."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Condividi i tuoi sintomi, ti guiderò verso la specialità giusta."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deel uw symptomen, ik zal u naar het juiste specialisme leiden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Opisz swoje objawy, a ja wskażę odpowiednią specjalizację."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Compartilhe seus sintomas, eu o guiarei para a especialidade certa."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Împărtășește-ți simptomele, te voi ghida către specialitatea potrivită."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опишите свои симптомы, я направлю вас к нужному специалисту."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dela dina symptom, jag guidar dig till rätt specialitet."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Belirtilerinizi paylaşın, sizi doğru uzmanlığa yönlendireceğim."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Опишіть свої симптоми, і я підкажу вам потрібну спеціалізацію."
          }
        }
      }
    },
    "rehber_empty_state_sub": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Není poskytována žádná diagnóza ani léčba; pouze doporučení."
          }
        },
