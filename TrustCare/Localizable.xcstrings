          "stringUnit": {
            "state": "translated",
            "value": "Hat der Arzt zugehört und klar erklärt?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Did the doctor listen and explain clearly?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿El médico escuchó y explicó claramente?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le médecin vous a-t-il écouté et expliqué clairement ?"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az orvos meghallgatta és érthetően elmagyarázott mindent?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il medico ti ha ascoltato e ha spiegato in modo chiaro?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Luisterde de arts en legde deze alles duidelijk uit?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Czy lekarz wysłuchał i jasno wszystko wyjaśnił?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O médico ouviu e explicou com clareza?"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Medicul a ascultat și a explicat clar?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Врач выслушал вас и понятно всё объяснил?"
