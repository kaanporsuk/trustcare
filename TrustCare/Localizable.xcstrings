    "tos_service_1": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Společnost TrustCare poskytuje funkce pro vyhledávání a hodnocení ve zdravotnictví a informační nástroje pro běžné spotřebitelské použití."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "TrustCare leverer opdagelse af sundhedspleje, anmeldelsesfunktioner og informative vejledningsværktøjer til almindelig forbrugerbrug."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "TrustCare bietet Suchfunktionen für das Gesundheitswesen, Bewertungsfunktionen und informative Hilfsmittel für den allgemeinen Verbrauchergebrauch."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "TrustCare provides healthcare discovery, review features, and informational guidance tools for general consumer use."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "TrustCare ofrece búsqueda de servicios de salud, reseñas y herramientas de orientación informativa para el uso general de los consumidores."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "TrustCare fournit des outils de recherche de professionnels de santé, d'évaluation et de conseils informatifs destinés au grand public."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A TrustCare egészségügyi kereső-, értékelési funkciókat és információs útmutató eszközöket kínál általános fogyasztói használatra."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "TrustCare fornisce funzioni di ricerca in ambito sanitario, recensioni e strumenti di orientamento informativo per uso generale dei consumatori."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "TrustCare biedt zoekfuncties voor gezondheidszorg, beoordelingsfuncties en informatieve tools voor algemeen consumentengebruik."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "TrustCare oferuje wyszukiwarkę usług zdrowotnych, możliwość dodawania opinii i narzędzia doradcze ogólnego przeznaczenia."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A TrustCare fornece ferramentas de busca de saúde, recursos de avaliação e ferramentas de orientação informativa para o uso geral do consumidor."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "TrustCare oferă descoperire în domeniul sănătății, funcții de recenzie și instrumente de orientare informativă pentru uzul general al consumatorilor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "TrustCare предоставляет инструменты поиска медицинских услуг и отзывов для широкого использования."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "TrustCare tillhandahåller funktioner för att upptäcka och recensera sjukvård samt informations- och vägledningsverktyg för allmänt konsumentbruk."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "TrustCare, genel tüketici kullanımı için sağlık hizmeti keşfi, değerlendirme özellikleri ve bilgilendirici rehberlik araçları sağlar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "TrustCare надає інструменти для пошуку медичних послуг, публікації відгуків та отримання інформаційних рекомендацій для широкого кола користувачів."
          }
        }
      }
    },
    "tos_service_2": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Dostupnost služeb, funkce a přístup se mohou v průběhu času měnit; můžeme aktualizovat nebo ukončit části služby bez předchozího upozornění."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tjenestens tilgængelighed, funktioner og adgang kan ændre sig over tid; vi kan opdatere eller afbryde dele af tjenesten uden forudgående varsel."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Verfügbarkeit, Funktionen und der Zugang zum Dienst können sich im Laufe der Zeit ändern; wir können Teile des Dienstes ohne vorherige Ankündigung aktualisieren oder einstellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Service availability, features, and access may change over time; we may update or discontinue parts of the service without prior notice."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La disponibilidad del servicio, las funciones y el acceso pueden cambiar con el tiempo; podemos actualizar o suspender partes del servicio sin previo aviso."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La disponibilité, les fonctionnalités et l'accès au service peuvent évoluer ; nous pouvons mettre à jour ou interrompre certaines parties du service sans préavis."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A szolgáltatás elérhetősége, a funkciók és a hozzáférés idővel változhat; előzetes értesítés nélkül frissíthetjük vagy megszüntethetjük a szolgáltatás egyes részeit."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La disponibilità, le funzionalità e l'accesso al servizio possono cambiare nel tempo; potremmo aggiornare o interrompere parti del servizio senza preavviso."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Beschikbaarheid van de service, functies en toegang kunnen in de loop van de tijd veranderen; we kunnen delen van de service zonder voorafgaande kennisgeving bijwerken of stopzetten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dostępność, funkcje i dostęp do usługi mogą ulegać zmianom; możemy aktualizować lub zamykać część usług bez wcześniejszego powiadomienia."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A disponibilidade do serviço, recursos e acesso podem mudar com o tempo; podemos atualizar ou descontinuar partes do serviço sem aviso prévio."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Disponibilitatea serviciului, funcțiile și accesul se pot schimba în timp; putem actualiza sau întrerupe părți ale serviciului fără notificare prealabilă."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступность и функции могут меняться; мы можем обновлять или прекращать работу частей сервиса без уведомления."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tjänstens tillgänglighet, funktioner och åtkomst kan ändras över tid; vi kan uppdatera eller avbryta delar av tjänsten utan föregående meddelande."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hizmetin kullanılabilirliği, özellikleri ve erişimi zamanla değişebilir; önceden haber vermeksizin hizmetin bazı kısımlarını güncelleyebilir veya sonlandırabiliriz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступність сервісу, його функції та доступ можуть змінюватися з часом; ми можемо оновлювати або припиняти роботу частини сервісу без попереднього повідомлення."
          }
        }
      }
    },
