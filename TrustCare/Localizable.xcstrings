    "tos_review_1": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Recenze musí odrážet skutečné zkušenosti z první ruky a nesmí obsahovat obtěžování, projevy nenávisti ani nezákonný obsah."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Anmeldelser skal afspejle ægte, førstehåndsoplevelser og må ikke indeholde chikane, hadefuld tale eller ulovligt indhold."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bewertungen müssen echte Erfahrungen aus erster Hand widerspiegeln und dürfen keine Belästigungen, Hassreden oder rechtswidrige Inhalte enthalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reviews must reflect genuine, firsthand experiences and must not include harassment, hate speech, or unlawful content."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las reseñas deben reflejar experiencias genuinas y de primera mano, y no deben incluir acoso, discursos de odio o contenido ilegal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les avis doivent refléter des expériences réelles de première main et ne doivent pas inclure de harcèlement, de discours de haine ou de contenu illégal."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az értékeléseknek valódi, első kézből származó tapasztalatokat kell tükrözniük, és nem tartalmazhatnak zaklatást, gyűlöletbeszédet vagy jogellenes tartalmat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le recensioni devono riflettere esperienze autentiche e dirette e non devono includere molestie, incitamento all'odio o contenuti illegali."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Beoordelingen moeten echte, persoonlijke ervaringen weerspiegelen en mogen geen intimidatie, haatzaaiende taal of illegale content bevatten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Opinie muszą odzwierciedlać prawdziwe doświadczenia i nie mogą zawierać nękania, mowy nienawiści ani bezprawnych treści."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As avaliações devem refletir experiências genuínas e em primeira mão e não devem incluir assédio, discurso de ódio ou conteúdo ilegal."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Recenziile trebuie să reflecte experiențe autentice, directe și nu trebuie să includă hărțuire, discurs instigator la ură sau conținut ilegal."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отзывы должны отражать реальный опыт и не содержать оскорблений, языка вражды или незаконного контента."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Recensioner måste återspegla äkta, förstahandsupplevelser och får inte innehålla trakasserier, hatretorik eller olagligt innehåll."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Değerlendirmeler gerçek, ilk elden deneyimleri yansıtmalı ve taciz, nefret söylemi veya yasa dışı içerik barındırmamalıdır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Відгуки повинні відображати справжній особистий досвід і не можуть містити домагань, мови ворожнечі або незаконного контенту."
          }
        }
      }
    },
    "tos_review_2": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Odesláním obsahu udělujete společnosti TrustCare licenci k hostování, zobrazování a moderování tohoto obsahu pro provoz služby."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ved at indsende indhold giver du TrustCare licens til at hoste, vise og moderere det indhold med henblik på driften af tjenesten."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durch das Einreichen von Inhalten gewähren Sie TrustCare eine Lizenz, diese Inhalte für den Betrieb des Dienstes zu hosten, anzuzeigen und zu moderieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "By submitting content, you grant TrustCare a license to host, display, and moderate that content for service operation."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al enviar contenido, otorgas a TrustCare una licencia para alojar, mostrar y moderar dicho contenido para el funcionamiento del servicio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "En soumettant du contenu, vous accordez à TrustCare une licence pour héberger, afficher et modérer ce contenu dans le cadre du fonctionnement du service."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A tartalom beküldésével licencet ad a TrustCare számára, hogy a szolgáltatás működtetése érdekében tárolja, megjelenítse és moderálja ezt a tartalmat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inviando contenuti, concedi a TrustCare una licenza per ospitare, mostrare e moderare tali contenuti per il funzionamento del servizio."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Door content in te dienen, verleent u TrustCare een licentie om die content te hosten, weer te geven en te modereren voor de werking van de service."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przesyłając treści, udzielasz TrustCare licencji na ich hostowanie, wyświetlanie i moderowanie w celu działania usługi."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ao enviar conteúdo, você concede à TrustCare uma licença para hospedar, exibir e moderar esse conteúdo para a operação do serviço."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Prin trimiterea conținutului, acorzi TrustCare o licență de a găzdui, afișa și modera acel conținut pentru funcționarea serviciului."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Размещая контент, вы предоставляете TrustCare лицензию на его использование для работы сервиса."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Genom att skicka in innehåll ger du TrustCare en licens att lagra, visa och moderera detta innehåll för driften av tjänsten."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İçerik göndererek, TrustCare'e bu içeriği barındırma, görüntüleme ve hizmetin işleyişi için denetleme lisansı vermiş olursunuz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Надсилаючи контент, ви надаєте TrustCare ліцензію на його розміщення, показ та модерацію для забезпечення роботи сервісу."
          }
        }
      }
    },
    "tos_review_3": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Můžeme odstranit, omezit nebo označit obsah, který porušuje zásady, zákonné povinnosti nebo standardy důvěry a bezpečnosti."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi kan fjerne, begrænse eller markere indhold, der overtræder politikker, juridiske forpligtelser eller standarder for tillid og sikkerhed."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir können Inhalte entfernen, einschränken oder markieren, die gegen Richtlinien, rechtliche Verpflichtungen oder Vertrauens- und Sicherheitsstandards verstoßen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We may remove, limit, or flag content that violates policy, legal obligations, or trust and safety standards."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Podemos eliminar, limitar o marcar el contenido que viole nuestras políticas, obligaciones legales o los estándares de confianza y seguridad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous pouvons supprimer, limiter ou signaler tout contenu qui enfreint la politique, les obligations légales ou les normes de confiance et de sécurité."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Eltávolíthatjuk, korlátozhatjuk vagy megjelölhetjük azokat a tartalmakat, amelyek sértik a szabályzatot, a jogi kötelezettségeket vagy a bizalmi és biztonsági előírásokat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Potremmo rimuovere, limitare o segnalare contenuti che violano le politiche, gli obblighi legali o gli standard di fiducia e sicurezza."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "We kunnen content verwijderen, beperken of markeren die beleid, wettelijke verplichtingen of vertrouwens- en veiligheidsnormen schendt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Możemy usuwać, ograniczać lub oznaczać treści, które naruszają regulamin, obowiązki prawne lub standardy zaufania i bezpieczeństwa."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Podemos remover, limitar ou sinalizar conteúdo que viole a política, as obrigações legais ou os padrões de confiança e segurança."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Putem elimina, limita sau marca conținutul care încalcă politicile, obligațiile legale sau standardele de încredere și siguranță."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы можем удалять или ограничивать контент, нарушающий политику или стандарты безопасности."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi kan ta bort, begränsa eller flagga innehåll som bryter mot policyn, rättsliga skyldigheter eller tillits- och säkerhetsstandarder."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Politikaları, yasal yükümlülükleri veya güven ve güvenlik standartlarını ihlal eden içeriği kaldırabilir, sınırlayabilir veya işaretleyebiliriz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ми можемо видаляти, обмежувати або позначати контент, що порушує політику, юридичні зобов'язання або стандарти безпеки та довіри."
          }
        }
      }
    },
