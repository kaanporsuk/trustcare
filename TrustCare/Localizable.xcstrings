    "rehber_consent_text": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Rozumím: Tyto návrhy slouží pouze jako vodítko, nejedná se o diagnózu"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeg forstår: Disse forslag er kun vejledende, ikke en diagnose"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich verstehe: Diese Vorschläge dienen nur zur Orientierung, nicht zur Diagnose"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I understand: These suggestions are for guidance only, not diagnosis"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Entiendo: Estas sugerencias son solo orientativas, no un diagnóstico"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je comprends : ces suggestions sont fournies à titre indicatif et ne constituent pas un diagnostic"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Megértettem: Ezek a javaslatok csak útmutatásra szolgálnak, nem diagnózis"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ho capito: questi suggerimenti sono solo indicativi, non costituiscono una diagnosi"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ik begrijp het: Deze suggesties zijn alleen voor richtlijnen, niet voor diagnose"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Rozumiem: Te sugestie służą jedynie jako wskazówki, a nie diagnoza"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Entendo: Estas sugestões são apenas orientações, não diagnósticos"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Înțeleg: Aceste sugestii sunt doar orientative, nu un diagnostic"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Я понимаю: эти советы носят лишь рекомендательный характер, а не являются диагнозом"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Jag förstår: Dessa förslag är endast vägledande, inte en diagnos"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
