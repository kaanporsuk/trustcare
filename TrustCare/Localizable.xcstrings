    "review_criterion_bedside_manner_question": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Naslouchal lékař a vše jasně vysvětlil?"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Lyttede lægen og forklarede klart?"
