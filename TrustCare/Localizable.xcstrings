    "pp_data_usage_1" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vi bruger personoplysninger til at levere kernefunktioner, personalisere indhold og opretholde kontosikkerhed."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir verwenden personenbezogene Daten, um Kernfunktionen bereitzustellen, Inhalte zu personalisieren und Kontosicherheit zu gewährleisten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We use personal data to provide core app functionality, personalize content, and maintain account security."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We gebruiken persoonsgegevens om kernfunctionaliteit te leveren, content te personaliseren en accountbeveiliging te behouden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dane osobowe wykorzystujemy do świadczenia funkcji aplikacji, personalizacji treści i ochrony konta."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kişisel verileri temel uygulama işlevlerini sunmak, içeriği kişiselleştirmek ve hesap güvenliğini sağlamak için kullanırız."
          }
        }
      }
    },
    "pp_data_usage_2" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indsendte anmeldelser og metadata bruges til tillid og sikkerhed, moderation, svindelforebyggelse og kvalitetssikring."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eingereichte Bewertungen und Metadaten nutzen wir für Vertrauen, Sicherheit, Moderation, Betrugsprävention und Qualitätssicherung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We use submitted reviews and metadata for trust, safety, moderation, fraud prevention, and quality assurance."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ingediende beoordelingen en metadata gebruiken we voor vertrouwen en veiligheid, moderatie, fraudepreventie en kwaliteitsborging."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opinie i metadane wykorzystujemy do zaufania i bezpieczeństwa, moderacji, zapobiegania nadużyciom oraz zapewnienia jakości."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gönderilen değerlendirme ve meta verileri güven, emniyet, moderasyon, dolandırıcılığı önleme ve kalite amaçlarıyla kullanırız."
          }
        }
      }
    },
    "pp_data_usage_3" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aggregeret og anonymiseret analyse kan bruges til at forbedre produktoplevelse og driftssikkerhed."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aggregierte und anonymisierte Analysen können zur Verbesserung von Produkterlebnis und Zuverlässigkeit genutzt werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We may use aggregated and de-identified analytics to improve product experience and reliability."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geaggregeerde en geanonimiseerde analytics kunnen worden gebruikt om productervaring en betrouwbaarheid te verbeteren."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zagregowane i zanonimizowane analizy mogą być używane do poprawy doświadczenia i niezawodności produktu."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ürün deneyimini ve güvenilirliği geliştirmek için toplulaştırılmış ve kimliksizleştirilmiş analizlerden yararlanabiliriz."
          }
        }
      }
    },
