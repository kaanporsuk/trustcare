    "tos_contact_1": {
      "extractionState": "stale",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Dotazy týkající se těchto Podmínek lze zasílat na adresu support@trustcare.app."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Spørgsmål om disse vilkår kan sendes til support@trustcare.app."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fragen zu diesen Bedingungen können an support@trustcare.app gesendet werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Questions about these Terms can be sent to support@trustcare.app."
          }
        },
        "es": {
